<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_packimmo_search_carousel_image_tree" model="ir.ui.view">
        <field name="name">packimmo.search.carousel.image.tree</field>
        <field name="model">packimmo.search.carousel.image</field>
        <field name="arch" type="xml">
            <tree string="Images carousel recherche" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="image" widget="image" options="{'size': [60, 60]}"/>
                <field name="website_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_packimmo_search_carousel_image_form" model="ir.ui.view">
        <field name="name">packimmo.search.carousel.image.form</field>
        <field name="model">packimmo.search.carousel.image</field>
        <field name="arch" type="xml">
            <form string="Image carousel recherche">
                <sheet>
                    <group>
                        <field name="website_id"/>
                        <field name="sequence"/>
                        <field name="name"/>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_packimmo_search_carousel_image" model="ir.actions.act_window">
        <field name="name">Carousel Immobilier</field>
        <field name="res_model">packimmo.search.carousel.image</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_packimmo_search_carousel_image_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Ajoutez des images de fond pour le carousel de la page de recherche.
            </p>
        </field>
    </record>

    <record id="menu_packimmo_search_carousel_image" model="ir.ui.menu">
        <field name="name">Carousel Immobilier</field>
        <field name="parent_id" ref="website.menu_website_global_configuration"/>
        <field name="action" ref="action_packimmo_search_carousel_image"/>
        <field name="sequence">20</field>
    </record>

</odoo>
