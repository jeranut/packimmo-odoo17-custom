<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_packimmo_search_carousel" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.packimmo.search.carousel</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <!-- Odoo 17 settings view uses <app name="website">, not div.settings -->
            <xpath expr="//app[@name='website']" position="inside">

                <block title="Carousel Immobilier" name="packimmo_search_carousel_block">
                    <setting id="packimmo_search_carousel_setting" string="Images derrière la barre de recherche" help="Ajoutez les images affichées en arrière-plan derrière la barre de recherche de la page des biens. Format conseillé : 1920 x 900 px.">

                        <field name="packimmo_search_carousel_image_ids" nolabel="1" colspan="2" mode="tree,form">
                            <tree editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="active"/>
                            </tree>
                            <form>
                                <sheet>
                                    <group>
                                        <field name="website_id" invisible="1"/>
                                        <field name="sequence"/>
                                        <field name="name"/>
                                        <field name="image" widget="image" class="oe_avatar"/>
                                        <field name="active"/>
                                    </group>
                                </sheet>
                            </form>
                        </field>

                    </setting>
                </block>

            </xpath>

        </field>
    </record>

</odoo>
