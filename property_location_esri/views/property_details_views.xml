<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="property_details_form_view_inherit_location_esri" model="ir.ui.view">
        <field name="name">property.details.form.location.esri</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        type="object"
                        name="action_open_location_picker"
                        icon="fa-map-marker"
                        string="Définir localisation">
                </button>
            </xpath>

            <xpath expr="//field[@name='latitude']" position="attributes">
                <attribute name="string">Latitude</attribute>
            </xpath>
            <xpath expr="//field[@name='longitude']" position="attributes">
                <attribute name="string">Longitude</attribute>
            </xpath>
        </field>
    </record>
</odoo>
