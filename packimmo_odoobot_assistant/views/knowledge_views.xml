<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_packimmo_knowledge_workflow_tree" model="ir.ui.view">
        <field name="name">packimmo.knowledge.workflow.tree</field>
        <field name="model">packimmo.knowledge.workflow</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_packimmo_knowledge_workflow_form" model="ir.ui.view">
        <field name="name">packimmo.knowledge.workflow.form</field>
        <field name="model">packimmo.knowledge.workflow</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="group_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_packimmo_knowledge_workflows" model="ir.actions.act_window">
        <field name="name">Workflows</field>
        <field name="res_model">packimmo.knowledge.workflow</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_packimmo_knowledge_category_tree" model="ir.ui.view">
        <field name="name">packimmo.knowledge.category.tree</field>
        <field name="model">packimmo.knowledge.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="workflow_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_packimmo_knowledge_category_form" model="ir.ui.view">
        <field name="name">packimmo.knowledge.category.form</field>
        <field name="model">packimmo.knowledge.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="workflow_id"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_packimmo_knowledge_categories" model="ir.actions.act_window">
        <field name="name">Catégories</field>
        <field name="res_model">packimmo.knowledge.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_packimmo_knowledge_article_tree" model="ir.ui.view">
        <field name="name">packimmo.knowledge.article.tree</field>
        <field name="model">packimmo.knowledge.article</field>
        <field name="arch" type="xml">
            <tree decoration-muted="not active">
                <field name="priority" widget="handle"/>
                <field name="title"/>
                <field name="workflow_id"/>
                <field name="category_id"/>
                <field name="external_id"/>
                <field name="difficulty"/>
                <field name="suggested"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_packimmo_knowledge_article_search" model="ir.ui.view">
        <field name="name">packimmo.knowledge.article.search</field>
        <field name="model">packimmo.knowledge.article</field>
        <field name="arch" type="xml">
            <search>
                <field name="title"/>
                <field name="question"/>
                <field name="external_id"/>
                <field name="workflow_id"/>
                <field name="category_id"/>
                <filter name="suggested" string="Suggérées" domain="[('suggested', '=', True)]"/>
                <filter name="active" string="Actives" domain="[('active', '=', True)]"/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_workflow" string="Workflow" context="{'group_by': 'workflow_id'}"/>
                    <filter name="group_category" string="Catégorie" context="{'group_by': 'category_id'}"/>
                    <filter name="group_difficulty" string="Difficulté" context="{'group_by': 'difficulty'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_packimmo_knowledge_article_form" model="ir.ui.view">
        <field name="name">packimmo.knowledge.article.form</field>
        <field name="model">packimmo.knowledge.article</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1><field name="title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="workflow_id"/>
                            <field name="category_id"/>
                            <field name="external_id"/>
                            <field name="version"/>
                        </group>
                        <group>
                            <field name="difficulty"/>
                            <field name="priority"/>
                            <field name="sequence"/>
                            <field name="suggested"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="group_ids" widget="many2many_tags"/>
                        <field name="menu_path"/>
                        <field name="target_model"/>
                        <field name="guide_anchor"/>
                        <field name="source_reference"/>
                    </group>
                    <notebook>
                        <page string="Question">
                            <field name="question"/>
                        </page>
                        <page string="Réponse">
                            <field name="answer" widget="html"/>
                        </page>
                        <page string="Mots-clés">
                            <field name="keyword_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Formulations">
                            <field name="question_variant_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Workflow">
                            <group>
                                <field name="prerequisites"/>
                                <field name="steps"/>
                                <field name="tips"/>
                                <field name="errors"/>
                            </group>
                        </page>
                        <page string="Images">
                            <field name="image_ids" mode="tree,form">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="title"/>
                                    <field name="caption"/>
                                    <field name="active"/>
                                </tree>
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="title"/>
                                                <field name="caption"/>
                                                <field name="sequence"/>
                                                <field name="active"/>
                                            </group>
                                            <group>
                                                <field name="image" widget="image"/>
                                            </group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Vidéos YouTube">
                            <field name="video_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="title"/>
                                    <field name="youtube_url"/>
                                    <field name="duration"/>
                                    <field name="active"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Documents PDF">
                            <field name="document_ids" mode="tree,form">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="filename"/>
                                    <field name="description"/>
                                    <field name="active"/>
                                </tree>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="name"/>
                                            <field name="file" filename="filename"/>
                                            <field name="filename" invisible="1"/>
                                            <field name="description"/>
                                            <field name="sequence"/>
                                            <field name="active"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Liens">
                            <field name="link_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="title"/>
                                    <field name="url"/>
                                    <field name="description"/>
                                    <field name="active"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Questions similaires">
                            <field name="related_question_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_packimmo_knowledge_articles" model="ir.actions.act_window">
        <field name="name">Articles</field>
        <field name="res_model">packimmo.knowledge.article</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

