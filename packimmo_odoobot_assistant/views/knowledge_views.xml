            </tree>
        </field>
    </record>

    <record id="view_packimmo_knowledge_link_form" model="ir.ui.view">
        <field name="name">packimmo.knowledge.link.form</field>
        <field name="model">packimmo.knowledge.link</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="article_id"/>
                        <field name="title"/>
                        <field name="url"/>
                        <field name="description"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_packimmo_knowledge_unanswered_tree" model="ir.ui.view">
        <field name="name">packimmo.knowledge.unanswered.question.tree</field>
        <field name="model">packimmo.knowledge.unanswered.question</field>
        <field name="arch" type="xml">
            <tree decoration-muted="status in ('done', 'ignored')">
                <field name="create_date"/>
                <field name="question"/>
                <field name="user_id"/>
                <field name="workflow_suggested"/>
                <field name="best_score"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_packimmo_knowledge_unanswered_form" model="ir.ui.view">
        <field name="name">packimmo.knowledge.unanswered.question.form</field>
        <field name="model">packimmo.knowledge.unanswered.question</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_in_review" type="object" string="Analyser" invisible="status != 'new'"/>
                    <button name="action_create_article" type="object" string="Créer un article" class="btn-primary"/>
                    <button name="action_link_existing_article" type="object" string="Lier l'article" invisible="not linked_article_id"/>
                    <button name="action_mark_done" type="object" string="Marquer traité"/>
                    <button name="action_mark_ignored" type="object" string="Ignorer"/>
                    <field name="status" widget="statusbar" statusbar_visible="new,in_review,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="user_role"/>
                            <field name="workflow_suggested"/>
                            <field name="best_score"/>
                        </group>
                        <group>
                            <field name="created_article_id"/>
                            <field name="linked_article_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="question"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_packimmo_knowledge_unanswered" model="ir.actions.act_window">
        <field name="name">Questions sans réponse</field>
        <field name="res_model">packimmo.knowledge.unanswered.question</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_packimmo_knowledge_sync_wizard_form" model="ir.ui.view">
        <field name="name">packimmo.knowledge.sync.wizard.form</field>
        <field name="model">packimmo.knowledge.sync.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <p>
                        Synchronise les datasets MIA depuis le chemin externe configuré dans les paramètres MIA.
                        Par défaut, la synchronisation enrichit la base sans supprimer les articles ni les médias manuels.
                    </p>
                    <group string="Options de synchronisation">
                        <field name="create_new_articles"/>
                        <field name="update_existing_articles"/>
                        <field name="delete_missing_articles"/>
                        <field name="reimport_media"/>
                    </group>
                    <group string="Import ZIP optionnel">
                        <field name="zip_file" filename="zip_filename"/>
                        <field name="zip_filename" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_sync_datasets" type="object" string="Synchroniser les datasets MIA" class="btn-primary"/>
                    <button name="action_import_zip" type="object" string="Importer un ZIP de datasets" class="btn-secondary"/>
                    <button string="Fermer" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_packimmo_knowledge_sync" model="ir.actions.act_window">
        <field name="name">Synchronisation</field>
        <field name="res_model">packimmo.knowledge.sync.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_packimmo_knowledge_statistics" model="ir.actions.act_window">
        <field name="name">Statistiques</field>
        <field name="res_model">packimmo.knowledge.article</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="context">{'group_by': ['workflow_id', 'category_id']}</field>
    </record>

    <menuitem id="menu_packimmo_mia_root" name="MIA" sequence="20"/>
    <menuitem id="menu_packimmo_knowledge_workflows" name="Workflows" parent="menu_packimmo_mia_root" action="action_packimmo_knowledge_workflows" sequence="10"/>
    <menuitem id="menu_packimmo_knowledge_articles" name="Articles" parent="menu_packimmo_mia_root" action="action_packimmo_knowledge_articles" sequence="20"/>
    <menuitem id="menu_packimmo_knowledge_categories" name="Catégories" parent="menu_packimmo_mia_root" action="action_packimmo_knowledge_categories" sequence="30"/>
    <menuitem id="menu_packimmo_knowledge_media" name="Médias" parent="menu_packimmo_mia_root" sequence="40"/>
    <menuitem id="menu_packimmo_knowledge_images" name="Images" parent="menu_packimmo_knowledge_media" action="action_packimmo_knowledge_images" sequence="10"/>
    <menuitem id="menu_packimmo_knowledge_videos" name="Vidéos YouTube" parent="menu_packimmo_knowledge_media" action="action_packimmo_knowledge_videos" sequence="20"/>
    <menuitem id="menu_packimmo_knowledge_documents" name="Documents PDF" parent="menu_packimmo_knowledge_media" action="action_packimmo_knowledge_documents" sequence="30"/>
    <menuitem id="menu_packimmo_knowledge_unanswered" name="Questions sans réponse" parent="menu_packimmo_mia_root" action="action_packimmo_knowledge_unanswered" sequence="50"/>
    <menuitem id="menu_packimmo_knowledge_sync" name="Synchronisation" parent="menu_packimmo_mia_root" action="action_packimmo_knowledge_sync" sequence="60"/>
    <menuitem id="menu_packimmo_knowledge_statistics" name="Statistiques" parent="menu_packimmo_mia_root" action="action_packimmo_knowledge_statistics" sequence="70"/>
</odoo>
