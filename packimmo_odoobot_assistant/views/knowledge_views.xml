    <record id="view_packimmo_knowledge_document_tree" model="ir.ui.view">
        <field name="name">packimmo.knowledge.document.tree</field>
        <field name="model">packimmo.knowledge.document</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="article_id"/>
                <field name="filename"/>
