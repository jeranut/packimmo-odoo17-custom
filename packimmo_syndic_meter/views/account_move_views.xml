<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_inherit_meter_fee_info" model="ir.ui.view">
        <field name="name">account.move.form.inherit.meter.fee.info</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="before">
                <div class="alert alert-info mb-2"
                    invisible="not meter_fixed_fee_label">
                    <strong>Information redevance : </strong>
                    <field name="meter_fixed_fee_label"
                        readonly="1"
                        nolabel="1"
                        class="oe_inline" />
                </div>
            </xpath>

        </field>
    </record>

</odoo>