<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_property_mandate_sale_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-set="Date" t-value="datetime.date" />
                    <t t-set="partner" t-value="doc.owner_id" />

                    <div class="page">
                        <div class="text-center mb-4 pack-title">
                            <h2>MANDAT DE VENTE N° <span t-field="doc.name" /></h2>
                        </div>

                        <table style="width:100%; margin-bottom:25px;">
                            <tr>
                                <td style="width:33%; text-align:center;">
                                    <strong>
                                        <t t-if="doc.mandate_type == 'simple'">[X]</t>
                                        <t t-else="">☐</t>
                                        NON EXCLUSIF
                                    </strong>
                                </td>
                                <td style="width:33%; text-align:center;">
                                    <strong>
                                        <t t-if="doc.mandate_type == 'exclusive'">[X]</t>
                                        <t t-else="">☐</t>
                                        EXCLUSIF
                                    </strong>
                                </td>
                                <td style="width:33%; text-align:center;">
                                    <strong>
                                        <t t-if="doc.mandate_type == 'exclusive_absolute'">[X]</t>
                                        <t t-else="">☐</t>
                                        EXCLUSIF ABSOLU
                                    </strong>
                                </td>
                            </tr>
                        </table>

                        <div style="margin-bottom: 12px; line-height: 1.2;">
                            <div>
                                <strong style="text-decoration: underline;">
                                    Entre les soussignés :
                                </strong>
                            </div>
                            <div>
                                PACKIMMO S.A., NIF 20000 360 20 RCS 2007 B 00645, sise
                                établissement Ranohisoa, Route des Hydrocarbures Ankorondrano
                                représentée par son Directeur Général ayant tout pouvoir à cet
                                effet.
                            </div>
                            <div style="text-align: center;">
                                Ci-après dénommé « Le MANDATAIRE » d’une part,
                            </div>
                        </div>
                        <p>Et :</p>

                        <!-- PROPRIÉTAIRE : PERSONNE PHYSIQUE -->
                        <t t-if="partner and partner.company_type == 'person'">
                            <p>
                                Monsieur / Madame / Mademoiselle :
                                <span class="pack-value">
                                    <t t-esc="partner.display_name or ''" />
                                </span>
                            </p>

                            <table class="pk-table" style="width:100%;">
                                <tr>
                                    <td style="width:18%;"><strong>Nationalité :</strong></td>
                                    <td style="width:32%;">
                                        <span t-esc="partner.nationality_id.name if 'nationality_id' in partner._fields and partner.nationality_id else ''" />
                                    </td>
                                    <td style="width:18%;"><strong>Profession :</strong></td>
                                    <td style="width:32%;"><span t-esc="partner.function or ''" /></td>
                                </tr>
                                <tr>
                                    <td><strong>CIN / Passeport N° :</strong></td>
                                    <td><span t-esc="partner.cin if 'cin' in partner._fields else ''" /></td>
                                    <td><strong>Délivré(e) le :</strong></td>
                                    <td>
                                        <span t-esc="partner.cin_delivery_date.strftime('%d/%m/%Y') if 'cin_delivery_date' in partner._fields and partner.cin_delivery_date else ''" />
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>À :</strong></td>
                                    <td><span t-esc="partner.cin_delivery_place if 'cin_delivery_place' in partner._fields else ''" /></td>
                                    <td><strong>Téléphone :</strong></td>
                                    <td><span t-esc="partner.phone or partner.mobile or ''" /></td>
                                </tr>
                                <tr>
                                    <td><strong>E-mail :</strong></td>
                                    <td><span t-esc="partner.email or ''" /></td>
                                    <td><strong>Adresse :</strong></td>
                                    <td><span t-esc="partner.contact_address or partner.street or ''" /></td>
                                </tr>
                            </table>
                        </t>

                        <!-- PROPRIÉTAIRE : SOCIÉTÉ / PERSONNE MORALE -->
                        <t t-if="partner and partner.company_type == 'company'">
                            <p>
                                <strong>La Société / Raison Sociale :</strong>
                                <span><t t-esc="partner.name or ''" /></span>
                            </p>

                            <table class="pk-table" style="width:100%;">
                                <tr>
                                    <td style="width:20%;"><strong>Forme juridique :</strong></td>
                                    <td style="width:30%;">
                                        <span t-esc="partner.legal_form_id.name if 'legal_form_id' in partner._fields and partner.legal_form_id else ''" />
                                    </td>
                                    <td style="width:20%;"><strong>Capital :</strong></td>
                                    <td style="width:30%;">
                                        <span t-esc="'{:,.0f}'.format(partner.share_capital).replace(',', ' ') if 'share_capital' in partner._fields and partner.share_capital else ''" />
                                        <t t-if="'share_capital' in partner._fields and partner.share_capital"> Ar</t>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Siège social :</strong></td>
                                    <td colspan="3"><span t-esc="partner.contact_address or partner.street or ''" /></td>
                                </tr>
                                <tr>
                                    <td><strong>NIF :</strong></td>
                                    <td><span t-esc="partner.nif if 'nif' in partner._fields else ''" /></td>
                                    <td><strong>STAT :</strong></td>
                                    <td><span t-esc="partner.stat if 'stat' in partner._fields else ''" /></td>
                                </tr>
                                <tr>
                                    <td><strong>RCS :</strong></td>
                                    <td><span t-esc="partner.rcs if 'rcs' in partner._fields else ''" /></td>
                                    <td><strong>Téléphone :</strong></td>
                                    <td><span t-esc="partner.phone or partner.mobile or ''" /></td>
                                </tr>
                                <tr>
                                    <td><strong>Représentée par :</strong></td>
                                    <td>
                                        <span t-esc="partner.representative_id.display_name if 'representative_id' in partner._fields and partner.representative_id else ''" />
                                    </td>
                                    <td><strong>En qualité de :</strong></td>
                                    <td>
                                        <span t-esc="partner.quality_id.name if 'quality_id' in partner._fields and partner.quality_id else ''" />
                                    </td>
                                </tr>
                            </table>
                        </t>

                        <p>
                            Ci-après dénommé <strong>le mandant</strong>, lequel confère au
                            mandataire, qui l’accepte, le mandat de rechercher un acquéreur pour
                            le ou les biens désignés ci-dessous.
                        </p>

                        <h4 class="pk-section-title">
                            I — Désignation des biens et prix de vente
                        </h4>
                        <p>(La description détaillée fait l’objet d’une fiche séparée)</p>

                        <t t-if="doc.property_ids">
                            <t t-foreach="doc.property_ids" t-as="property">
                                <div class="pk-section-start">
                                    <!-- TERRAIN -->
                                    <t t-if="property.type == 'land'">
                                        <p class="pk-property-details"
                                            t-if="(property.property_project_id and (property.property_project_id.property_land_name or property.property_project_id.property_title_number)) or property.total_area or ('land_facilities' in property._fields and property.land_facilities)">
                                            <t
                                                t-if="property.property_project_id and property.property_project_id.property_land_name">
                                                <strong>Nom propriété :</strong>
                                                <span
                                                    t-esc="property.property_project_id.property_land_name" />
                                                /
                                            </t>
                                            <t
                                                t-if="property.property_project_id and property.property_project_id.property_title_number">
                                                <strong>Titre :</strong>
                                                <span
                                                    t-esc="property.property_project_id.property_title_number" />
                                                /
                                            </t>
                                            <t t-if="property.total_area">
                                                <strong>Superficie :</strong>
                                                <span t-esc="property.total_area" /> m² /
                                            </t>
                                            <t
                                                t-if="'land_facilities' in property._fields and property.land_facilities">
                                                <strong>Aménagements :</strong>
                                                <span t-esc="property.land_facilities" />
                                            </t>
                                        </p>
                                    </t>

                                    <!-- RÉSIDENTIEL ET COMMERCIAL -->
                                    <t t-if="property.type in ['residential', 'commercial']">
                                        <t t-set="has_property_details"
                                            t-value="(property.type == 'residential' and (('residence_type' in property._fields and property.residence_type) or ('unit_type' in property._fields and property.unit_type))) or (property.type == 'commercial' and (('property_subtype_id' in property._fields and property.property_subtype_id) or ('commercial_activity' in property._fields and property.commercial_activity))) or ('bed' in property._fields and property.bed) or ('bathroom' in property._fields and property.bathroom) or ('living_room_count' in property._fields and property.living_room_count) or ('room_measurement_ids' in property._fields and property.room_measurement_ids) or ('floor' in property._fields and property.floor is not False) or ('total_floor' in property._fields and property.total_floor) or ('unit_map_label' in property._fields and property.unit_map_label) or ('furnishing_id' in property._fields and property.furnishing_id) or ('total_square_ft' in property._fields and property.total_square_ft) or property.total_area or ('usable_square_ft' in property._fields and property.usable_square_ft) or property.usable_area or ('amenities_ids' in property._fields and property.amenities_ids)" />
                                        <p class="pk-property-details" t-if="has_property_details">
                                            <!-- BIEN RÉSIDENTIEL -->
                                            <t t-if="property.type == 'residential'">
                                                <t
                                                    t-if="'residence_type' in property._fields and property.residence_type">
                                                    <strong>Type résidence :</strong>
                                                    <span
                                                        t-esc="dict(property._fields['residence_type'].selection).get(property.residence_type, '')" />
                                                    /
                                                </t>
                                                <t
                                                    t-if="'unit_type' in property._fields and property.unit_type">
                                                    <strong>Type du bien :</strong>
                                                    <span
                                                        t-esc="dict(property._fields['unit_type'].selection).get(property.unit_type, '')" />
                                                    /
                                                </t>
                                            </t>

                                            <!-- BIEN COMMERCIAL -->
                                            <t t-set="property_subtype"
                                                t-value="property.property_subtype_id if 'property_subtype_id' in property._fields and property.property_subtype_id else False" />
                                            <t t-if="property.type == 'commercial'">
                                                <t t-if="property_subtype">
                                                    <strong>Type :</strong>
                                                    <span t-esc="property_subtype.name" /> /
                                                </t>
                                                <t
                                                    t-if="property_subtype and property_subtype.type == 'commercial' and property_subtype.category == 'commercial' and 'commercial_activity' in property._fields and property.commercial_activity">
                                                    <strong>Activité commerciale :</strong>
                                                    <span t-esc="property.commercial_activity" /> /
                                                </t>
                                            </t>

                                            <t t-if="'bed' in property._fields and property.bed">
                                                <strong>Pièce(s) :</strong>
                                                <span t-esc="property.bed" />
                                                <t
                                                    t-if="'room_measurement_ids' in property._fields and property.room_measurement_ids">
                                                    (<t
                                                        t-foreach="property.room_measurement_ids.filtered(lambda m: m.section_id and m.section_id.type == 'room')"
                                                        t-as="measure">
                                                        <span t-esc="measure.section_id.name" /> =
                                                        <span t-esc="measure.carpet_area" /> m²<t
                                                            t-if="not measure_last">, </t>
                                                    </t>)
                                                </t> /
                                            </t>

                                            <t
                                                t-if="'bathroom' in property._fields and property.bathroom">
                                                <strong>Salle de bain :</strong>
                                                <span t-esc="property.bathroom" />
                                                <t
                                                    t-if="'room_measurement_ids' in property._fields and property.room_measurement_ids">
                                                    (<t
                                                        t-foreach="property.room_measurement_ids.filtered(lambda m: m.section_id and m.section_id.type == 'bathroom')"
                                                        t-as="measure">
                                                        <span t-esc="measure.section_id.name" /> =
                                                        <span t-esc="measure.carpet_area" /> m²<t
                                                            t-if="not measure_last">, </t>
                                                    </t>)
                                                </t> /
                                            </t>

                                            <t
                                                t-if="'living_room_count' in property._fields and property.living_room_count">
                                                <strong>Séjour :</strong>
                                                <span t-esc="property.living_room_count" />
                                                <t
                                                    t-if="'room_measurement_ids' in property._fields and property.room_measurement_ids">
                                                    (<t
                                                        t-foreach="property.room_measurement_ids.filtered(lambda m: m.section_id and m.section_id.type == 'hall')"
                                                        t-as="measure">
                                                        <span t-esc="measure.section_id.name" /> =
                                                        <span t-esc="measure.carpet_area" /> m²<t
                                                            t-if="not measure_last">, </t>
                                                    </t>)
                                                </t> /
                                            </t>

                                            <t t-set="room_measurements"
                                                t-value="property.room_measurement_ids if 'room_measurement_ids' in property._fields else False" />
                                            <t t-set="parking_lines"
                                                t-value="room_measurements.filtered(lambda m: m.section_id and m.section_id.type == 'parking') if room_measurements else False" />
                                            <t t-if="parking_lines">
                                                <strong>Parking :</strong>
                                                <span
                                                    t-esc="sum(parking_lines.mapped('no_of_unit'))" />
                                                (<t t-foreach="parking_lines" t-as="measure">
                                                    <span t-esc="measure.section_id.name" /> =
                                                    <span t-esc="measure.carpet_area" /> m²<t
                                                        t-if="not measure_last">, </t>
                                                </t>) /
                                            </t>

                                            <t t-set="garage_lines"
                                                t-value="room_measurements.filtered(lambda m: m.section_id and m.section_id.name == 'Garage') if room_measurements else False" />
                                            <t t-if="garage_lines">
                                                <strong>Garage :</strong>
                                                <span
                                                    t-esc="sum(garage_lines.mapped('no_of_unit'))" />
                                                (<t t-foreach="garage_lines" t-as="measure">
                                                    <span t-esc="measure.section_id.name" /> =
                                                    <span t-esc="measure.carpet_area" /> m²<t
                                                        t-if="not measure_last">, </t>
                                                </t>) /
                                            </t>

                                            <t t-if="'floor_occupation' in property._fields and property.floor_occupation == 'whole_building'">
                                                <strong>Occupation :</strong> Immeuble entier /
                                            </t>
                                            <t
                                                t-elif="'floor_selection' in property._fields and property.floor_selection">
                                                <strong>Situé au :</strong>
                                                <span t-field="property.floor_selection" /> /
                                                <t
                                                    t-if="'unit_map_label' in property._fields and property.unit_map_label">
                                                    <strong>Porte/Lot N° :</strong>
                                                    <span t-esc="property.unit_map_label" /> /
                                                </t>
                                            </t>

                                            <t
                                                t-if="'total_floor' in property._fields and property.total_floor">
                                                <strong>Total étages :</strong>
                                                <span t-esc="property.total_floor" /> /
                                            </t>
                                            <t
                                                t-if="'furnishing_id' in property._fields and property.furnishing_id">
                                                <strong>Mobilier :</strong>
                                                <span t-esc="property.furnishing_id.name" /> /
                                            </t>
                                            <t
                                                t-if="('total_square_ft' in property._fields and property.total_square_ft) or property.total_area">
                                                <strong>Surface habitable :</strong>
                                                <span
                                                    t-esc="property.total_square_ft if 'total_square_ft' in property._fields and property.total_square_ft else property.total_area" />
                                                m² /
                                            </t>
                                            <t
                                                t-if="('usable_square_ft' in property._fields and property.usable_square_ft) or property.usable_area">
                                                <strong>Surface totale :</strong>
                                                <span
                                                    t-esc="property.usable_square_ft if 'usable_square_ft' in property._fields and property.usable_square_ft else property.usable_area" />
                                                m²
                                            </t>
                                            <t
                                                t-if="'amenities_ids' in property._fields and property.amenities_ids">
                                                / <strong>Commodités :</strong>
                                                <span
                                                    t-esc="', '.join(property.amenities_ids.mapped('display_name'))" />
                                            </t>
                                        </p>
                                    </t>

                                    <t t-set="address_source"
                                        t-value="property.subproject_id or property.property_project_id or property" />
                                    <p class="pk-property-location">
                                        <strong>Se situant à</strong>
                                        <span
                                            t-esc="' '.join(filter(None, [
                                                address_source.street or '',
                                                address_source.street2 or '',
                                                address_source.city_id.name if address_source.city_id else (address_source.city if 'city' in address_source._fields else ''),
                                                address_source.zip or ''
                                            ]))" />
                                    </p>

                                    <!-- Prix spécifique au terrain -->
                                    <t t-if="property.type == 'land'">
                                        <p t-if="'price_per_area' in property._fields and property.price_per_area">
                                            <strong>Prix de vente au m² :</strong>
                                            <span
                                                t-esc="'{:,.0f}'.format(property.price_per_area).replace(',', ' ')" />
                                            <span t-esc="doc.currency_id.symbol or 'Ar'" /> / m²
                                        </p>
                                        <p t-if="property.price">
                                            <strong>Prix de vente total :</strong>
                                            <span
                                                t-esc="'{:,.0f}'.format(property.price).replace(',', ' ')" />
                                            <span t-esc="doc.currency_id.symbol or 'Ar'" />
                                        </p>
                                    </t>

                                    <!-- Prix des biens résidentiels et commerciaux -->
                                    <p
                                        t-if="property.type != 'land' and (('foreign_price' in property._fields and property.foreign_price) or property.price)">
                                        <strong>Prix de vente :</strong>
                                        <t
                                            t-if="'foreign_price' in property._fields and property.foreign_price">
                                            <span
                                                t-esc="'{:,.0f}'.format(property.foreign_price).replace(',', ' ')" />
                                            <span
                                                t-esc="property.foreign_currency_id.symbol if property.foreign_currency_id else ''" />
                                        </t>
                                        <t t-else="">
                                            <span
                                                t-esc="'{:,.0f}'.format(property.price or 0.0).replace(',', ' ')" />
                                            <span t-esc="doc.currency_id.symbol or 'Ar'" />
                                        </t>
                                    </p>
                                </div>
                            </t>
                        </t>
                        <t t-else="">
                            <p>Aucun bien n’est encore rattaché à ce mandat.</p>
                        </t>

                        <div class="pk-section-start">
                            <h4 class="pk-section-title">
                                II — Mission et pouvoirs du mandataire
                            </h4>
                            <p>
                                Le mandataire est chargé de promouvoir les biens, organiser les
                                visites, recueillir les offres d’achat et présenter au mandant tout
                                acquéreur potentiel. Il peut utiliser, à ses frais, les moyens
                                publicitaires qu’il juge utiles. Toute vente demeure soumise à
                                l’acceptation du mandant et à la signature des actes requis.
                            </p>
                        </div>

                        <div class="pk-section-start">
                            <h4 class="pk-section-title">
                                III — Engagements du mandant
                            </h4>
                            <p>
                                Le mandant déclare être propriétaire des biens ou dûment habilité à
                                les vendre. Il s’engage à fournir les titres, plans, diagnostics et
                                documents nécessaires, à permettre les visites et à informer sans
                                délai le mandataire de toute offre ou vente.
                            </p>
                            <t t-if="doc.mandate_type == 'simple'">
                                <p>
                                    Le mandant conserve la faculté de vendre directement ou par
                                    l’intermédiaire d’un tiers, sous réserve d’en informer le
                                    mandataire dans les 48 heures.
                                </p>
                            </t>
                            <t t-if="doc.mandate_type == 'exclusive'">
                                <p>
                                    Pendant la durée du mandat, le mandant s’engage à ne confier la
                                    commercialisation à aucune autre agence. Il peut rechercher
                                    lui-même un acquéreur, sous réserve d’en informer le mandataire.
                                </p>
                            </t>
                            <t t-if="doc.mandate_type == 'exclusive_absolute'">
                                <p>
                                    La commercialisation est confiée exclusivement au mandataire.
                                    Toute vente réalisée pendant la durée du mandat ouvre droit aux
                                    honoraires convenus, y compris lorsque l’acquéreur est trouvé
                                    directement par le mandant.
                                </p>
                            </t>
                        </div>

                        <div class="pk-section-start">
                            <h4 class="pk-section-title">
                                IV — Particularité éventuelle du mandat
                            </h4>
                            <t t-if="doc.mandate_particularities">
                                <div class="pk-mandate-particularities"
                                    t-field="doc.mandate_particularities" />
                            </t>
                            <t t-else="">
                                <p>
                                    ***********************************************************<br />
                                    ***********************************************************
                                </p>
                            </t>
                        </div>

                        <div class="pk-section-start">
                            <h4 class="pk-section-title">
                                V — Durée du mandat
                            </h4>
                            <p>
                                Le présent mandat est donné pour une durée de
                                <strong><span t-field="doc.duration_months" /> mois</strong>,
                                du <strong><span t-field="doc.start_date" /></strong>
                                au <strong><span t-field="doc.end_date" /></strong>.
                            </p>
                            <t t-if="doc.tacit_renewal">
                                <p>
                                     renouvelable par tacite reconduction sauf dénonciation
                                    de l’une ou l’autre des parties, vingt (20) jours ouvrables avant la fin de la période par lettre
                                    recommandée avec accusé de réception.
                                </p>
                            </t>
                        </div>

                        <div class="pk-section-start">
                            <h4 class="pk-section-title">
                                VI — Honoraires
                            </h4>
                            <p t-if="doc.fee_calculation_label or doc.fee_amount_in_words">
                                Les honoraires de PACKIMMO sont fixés à
                                <strong t-if="doc.fee_calculation_label">
                                    <span t-esc="doc.fee_calculation_label" />
                                </strong>
                                <t t-if="doc.fee_amount_in_words">
                                    (<span t-esc="doc.fee_amount_in_words" />).
                                </t>
                            </p>
                            <p t-if="doc.billed_to">
                                Ils seront facturés
                                <t t-if="doc.billed_to == 'owner'">au mandant</t>
                                <t t-elif="doc.billed_to == 'tenant_buyer'">à l’acquéreur</t>
                                <t t-else="">au mandant et à l’acquéreur</t>,
                                selon les conditions convenues entre les parties.
                            </p>
                        </div>

                        <div class="pk-section-start">
                            <h4 class="pk-section-title">
                                VII — Attribution de juridiction
                            </h4>
                            <p>
                                Toute contestation relative à l’exécution du présent mandat sera
                                soumise à une tentative de règlement amiable. À défaut d’accord,
                                compétence est attribuée au Tribunal d’Antananarivo.
                            </p>
                        </div>

                        <div class="pack-signature-section">
                            <p>
                                Antananarivo le
                                <span class="pack-value">
                                    <t t-esc="Date.today().strftime('%d/%m/%Y')" />
                                </span>
                            </p>
                            <table class="pack-signature-box">
                                <tr>
                                    <td>
                                        <div class="pack-sign-title">Le Mandant</div>
                                        <div class="pack-sign-note">
                                            « Lu et approuvé, bon pour mandat de vente »
                                        </div>
                                        <div class="pack-sign-space"></div>
                                        <div class="pack-sign-line">—</div>
                                    </td>
                                    <td>
                                        <div class="pack-sign-title">
