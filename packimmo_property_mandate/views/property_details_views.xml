<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_property_details_form_inherit_mandate" model="ir.ui.view">
        <field name="name">property.details.form.inherit.mandate</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="is_company_property" invisible="1"/>
            </xpath>
             <xpath expr="//sheet" position="inside">
            <field name="property_subtype_category" invisible="1"/>
            </xpath>
             <xpath expr="//header/button[@name='action_draft_property']" position="after">
            <button name="action_open_mandate"
                    type="object"
                    string="Mandat"
                    class="btn btn-primary"
                    icon="fa-file-text-o"
                    invisible="is_company_property or (type == 'land' and property_subtype_category == 'morcellement')"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Mandat" name="mandate_details">
                    <group>
                        <group string="Mandat associé">
                            <field name="mandate_id" context="{'default_owner_id': landlord_id}" />
                            <field name="mandate_type" readonly="1" />
                            <field name="mandate_state" readonly="1" widget="badge" />
                            <field name="mandate_end_date" readonly="1" />
                        </group>

                        <group string="Règles">
                            <field name="mandate_exclusive" readonly="1" />
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
    <record id="property_details_form_view_inherit_mandate" model="ir.ui.view">
        <field name="name">property.details.form.view.inherit.mandate</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view" />

        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <field name="has_simple_mandate" invisible="1" />
                <field name="mandate_type" invisible="1" />
                <field name="mandate_state" invisible="1" />
            </xpath>

            <xpath expr="//button[@name='%(rental_management.contract_wizard_action)d']" position="attributes">
                <attribute name="invisible">stage not in ['available','on_lease'] or sale_lease != 'for_tenancy' or mandate_type in ['simple', 'exclusive'] or has_simple_mandate</attribute>
            </xpath>

            <xpath expr="//button[@name='%(rental_management.maintenance_wizard_action)d']" position="attributes">
                <attribute name="invisible">stage == 'draft' or mandate_type in ['simple', 'exclusive'] or has_simple_mandate</attribute>
            </xpath>

            <xpath expr="//button[@name='action_in_sale']" position="attributes">
                <attribute name="invisible">stage != 'available' or sale_lease != 'for_sale' or mandate_type in ['simple', 'exclusive']</attribute>
            </xpath>

        </field>
    </record>

    <record id="property_details_form_view_inherit_mandate_contract_button_checked" model="ir.ui.view">
        <field name="name">property.details.form.view.inherit.mandate.contract.button.checked</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="packimmo_rental_custom_fields.property_details_view_form_replace_create_contract_button" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_open_contract_wizard_checked']" position="attributes">
                <attribute name="invisible">stage not in ['available','on_lease'] or sale_lease != 'for_tenancy' or mandate_type in ['simple', 'exclusive'] or has_simple_mandate</attribute>
            </xpath>
        </field>
    </record>
</odoo>
