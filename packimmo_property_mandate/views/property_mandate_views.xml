<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_property_mandate_tree" model="ir.ui.view">
        <field name="name">property.mandate.tree</field>
        <field name="model">property.mandate</field>
        <field name="arch" type="xml">
            <tree string="Mandats">
                <field name="name" />
                <field name="company_id" groups="base.group_multi_company" />
                <field name="owner_id" />
                <field name="mandate_type" />
                <field name="operation_type" />
                <field name="start_date" />
                <field name="end_date" />
                <field name="property_count" />
                <field name="state" widget="badge" decoration-muted="state == 'draft'"
                    decoration-info="state == 'submitted'" decoration-primary="state == 'approved'"
                    decoration-success="state == 'active'" decoration-warning="state == 'completed'"
                    decoration-danger="state in ['expired', 'cancelled']" />
                <field name="invoice_payment_status"
                    widget="badge"
                    decoration-success="invoice_payment_status == 'paid'"
                    decoration-danger="invoice_payment_status == 'not_paid'"
                    decoration-warning="invoice_payment_status == 'partial'"
                    decoration-info="invoice_payment_status == 'in_payment'"
                    decoration-muted="invoice_payment_status in ['no_invoice', 'reversed']" />
            </tree>
        </field>
    </record>

    <record id="view_property_mandate_form" model="ir.ui.view">
        <field name="name">property.mandate.form</field>
        <field name="model">property.mandate</field>
        <field name="arch" type="xml">
            <form string="Mandat immobilier">
                <header>
                    <field name="company_id" invisible="1" />
                    <button name="action_submit" type="object" string="Soumettre"
                        class="btn-primary" invisible="state != 'draft'" />
                    <button name="action_approve" type="object" string="Approuver"
                        class="btn-primary" invisible="state != 'submitted'" />
                    <button name="action_activate" type="object" string="Activer"
                        class="btn-primary" invisible="state not in ('approved', 'draft')" />
                    <button name="action_expire" type="object" string="Expirer"
                        invisible="state != 'active'" />
                    <button name="action_cancel" type="object" string="Annuler"
                        invisible="state in ('cancelled', 'expired')" />
                    <button name="action_reset_to_draft" type="object"
                        string="Remettre en brouillon" invisible="state == 'draft'" />
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,submitted,approved,active" />
                    <button name="action_generate_mandate_pdf_to_chatter" type="object"
                        string="Imprimer le mandat" class="btn-primary" icon="fa-file-pdf-o"
                        invisible="state != 'active'" />
                    <button name="action_print_exclusive_contract"
                        type="object"
                        string="Imprimer contrat"
                        class="btn-primary"
                        icon="fa-print"
                        invisible="mandate_type != 'exclusive' or state != 'completed'" />
                    <button name="action_done_and_invoice"
                        type="object"
                        string="Terminer et facturer"
                        class="btn-primary"
                        invisible="state != 'active' or invoice_ids" />
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">

                        <button name="action_view_properties"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-home">
                            <field name="property_count"
                                widget="statinfo"
                                string="Biens" />
                        </button>

                        <button name="action_view_invoices"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-text-o"
                            invisible="invoice_count == 0">
                            <field name="invoice_count"
                                widget="statinfo"
                                string="Factures" />
                        </button>

                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_properties"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-home">
                            <field name="property_count"
                                widget="statinfo"
                                string="Biens" />
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group string="Informations générales">
                            <field name="company_id"
                                groups="base.group_multi_company"
                                options="{'no_create': True}" />
                            <field name="owner_id" readonly="1" />
                            <field name="mandate_type" readonly="state != 'draft'" />
                            <field name="operation_type" />

                            <field name="deposit_type" invisible="operation_type != 'rent'" />

                            <field name="deposit_month_count"
                                invisible="operation_type != 'rent' or deposit_type != 'monthly_multiple'"
                                required="operation_type == 'rent' and deposit_type == 'monthly_multiple'" />

                            <field name="deposit_fixed_amount"
                                invisible="operation_type != 'rent' or deposit_type != 'fixed'"
                                required="operation_type == 'rent' and deposit_type == 'fixed'" />

                            <field name="deposit_percent"
                                invisible="operation_type != 'rent' or deposit_type != 'annual_percent'"
                                required="operation_type == 'rent' and deposit_type == 'annual_percent'" />

                            <field name="deposit_amount" readonly="1"
                                invisible="operation_type != 'rent'" />
                            <field name="deposit_calculation_label" string="Détail calcul caution"
                                readonly="1" invisible="operation_type != 'rent'" />

                            <field name="billed_to" />
                            <field name="client_id"
                                invisible="billed_to == 'owner'" />

                            <field name="split_billing_type"
                                invisible="billed_to != 'both'" />

                            <field name="invoice_ids"
                                widget="many2many_tags"
                                readonly="1" />
                            <field name="invoice_payment_status"
                                widget="badge"
                                decoration-success="invoice_payment_status == 'paid'"
                                decoration-danger="invoice_payment_status == 'not_paid'"
                                decoration-warning="invoice_payment_status == 'partial'"
                                decoration-info="invoice_payment_status == 'in_payment'"
                                decoration-muted="invoice_payment_status == 'reversed'" />
                        </group>
                        <group string="Période">
                            <field name="start_date" readonly="1" />
                            <field name="duration_months" />
                            <field name="end_date" />
                            <field name="tacit_renewal" />
                        </group>
                    </group>
                    <group string="INFORMATION DU CONTRAT"
                        invisible="mandate_type != 'exclusive'">

                        <group>

                            <field name="contract_start_date" />

                            <field name="contract_duration_months" />

                            <field name="contract_end_date"
                                readonly="1" />

                            <field name="is_foreign_rent"
                                invisible="1" />

                            <!-- Type de loyer MGA -->
                            <field name="rent_type"
                                widget="radio"
                                readonly="1"
                                invisible="is_foreign_rent" />

                            <!-- Type de loyer devise -->
                            <field name="foreign_rent_type"
                                widget="radio"
                                invisible="not is_foreign_rent" />

                            <!-- Compte bancaire -->
                            <field name="rent_bank_account_id"
                                options="{'no_create': True, 'no_create_edit': True}" />
                            <field name="jirama_charge" />

                            <!-- Révision du loyer -->
                            <field name="rent_revision_option" />

                            <!-- Taux d'augmentation -->
                            <field name="revision_rate"
                                string="Taux d'augmentation (%)"
                                invisible="rent_revision_option not in ['fixed_annual','negotiated_biennial']" />

                        </group>


                    </group>
                    <group string="Exclusivité"
                        invisible="mandate_type in ['simple', 'exclusive']">
                        <field name="exclusive" />
                        <field name="priority_processing" />
                        <field name="commission_due_if_owner_rents" />
                    </group>
                    <group string="Honoraires">
                        <group>
                            <field name="fee_base_rent" string="Base honoraires location"
                                invisible="operation_type != 'rent'"
                                required="operation_type == 'rent'" />

                            <field name="fee_base_sale" string="Base honoraires vente"
                                invisible="operation_type != 'sale'"
                                required="operation_type == 'sale'" />

                            <field name="commission_percent" />
                            <field name="tax_percent" />
                        </group>

                        <group>
                            <field name="currency_id" invisible="1" />
                            <field name="fee_month_count"
                                invisible="operation_type != 'rent' or fee_base_rent != 'monthly_multiple'"
                                required="operation_type == 'rent' and fee_base_rent == 'monthly_multiple'" />

                            <field name="fee_base_amount" string="Montant mois de loyer"
                                readonly="1"
                                invisible="operation_type != 'rent' or fee_base_rent != 'monthly_multiple'" />

                            <field name="fee_base_amount" string="Loyer de référence" readonly="1"
                                invisible="operation_type != 'rent' or fee_base_rent != 'percent_rent'" />

                            <field name="fee_base_amount" string="Montant du prix de vente"
                                readonly="1"
                                invisible="operation_type != 'sale' or fee_base_sale != 'sale_price'" />

                            <field name="fee_base_amount" string="Prix de vente de référence"
                                readonly="1"
                                invisible="operation_type != 'sale' or fee_base_sale != 'percent_sale_price'" />

                            <field name="fixed_amount" string="Montant fixe"
                                invisible="(operation_type == 'rent' and fee_base_rent != 'fixed') or (operation_type == 'sale' and fee_base_sale != 'fixed')"
                                required="(operation_type == 'rent' and fee_base_rent == 'fixed') or (operation_type == 'sale' and fee_base_sale == 'fixed')" />

                            <field name="commission_amount" string="Pourcentage de la base"
                                readonly="1" />

                            <field name="tax_amount" string="Montant taxe" readonly="1" />

                            <field name="total_fee_amount" string="Total honoraires avec taxe"
                                readonly="1" />
                        </group>
                        <group colspan="2">
                            <field name="fee_calculation_label" string="Détail du calcul"
                                readonly="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Biens / Unités" name="properties">
                            <field name="property_ids"
                                domain="[('company_id', '=', company_id)]"
                                context="{'default_mandate_id': id, 'default_landlord_id': owner_id, 'default_company_id': company_id}">
                                <tree editable="bottom">
                                    <field name="name" />
                                    <field name="company_id" groups="base.group_multi_company" />
                                    <field name="landlord_id" />
                                    <field name="sale_lease" />
                                    <field name="stage" />
                                </tree>
                            </field>

                        </page>
                        <page string="Obligations" name="obligations">
                            <group>
                                <field name="owner_obligations"
                                    placeholder="Obligations du propriétaire..." />
                                <field name="agency_obligations"
                                    placeholder="Obligations de PACKIMMO..." />
                            </group>
                        </page>
                        <page string="Particularités du mandat" name="mandate_particularities">
                            <field name="mandate_particularities"
                                placeholder="Saisir les particularités éventuelles du mandat..." />
                        </page>
                        <page string="Documents" name="documents">
                            <field name="attachment_ids" widget="many2many_binary" />
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" />
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <record id="view_property_mandate_search" model="ir.ui.view">
        <field name="name">property.mandate.search</field>
        <field name="model">property.mandate</field>
        <field name="arch" type="xml">
            <search string="Mandats">
                <field name="name" />
                <field name="company_id" groups="base.group_multi_company" />
                <field name="owner_id" />
                <filter name="simple" string="Simple" domain="[('mandate_type','=','simple')]" />
                <filter name="exclusive" string="Exclusif"
                    domain="[('mandate_type','in',('exclusive','exclusive_absolute'))]" />
                <filter name="active" string="Actif" domain="[('state','=','active')]" />
                <group expand="0" string="Regrouper par">
                    <filter name="group_type" string="Type" context="{'group_by':'mandate_type'}" />
                    <filter name="group_state" string="État" context="{'group_by':'state'}" />
                    <filter name="group_owner" string="Propriétaire"
                        context="{'group_by':'owner_id'}" />
                    <filter name="group_company" string="Société"
                        context="{'group_by':'company_id'}"
                        groups="base.group_multi_company" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_property_mandate" model="ir.actions.act_window">
        <field name="name">Mandats</field>
        <field name="res_model">property.mandate</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_property_mandate_search" />
    </record>
    <record id="action_property_mandate_rent" model="ir.actions.act_window">
        <field name="name">Mandats location</field>
        <field name="res_model">property.mandate</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_property_mandate_tree" />
        <field name="domain">[('operation_type','=','rent')]</field>
        <field name="context">{'group_by':'mandate_type'}</field>
    </record>
    <record id="action_property_mandate_sale" model="ir.actions.act_window">
        <field name="name">Mandats vente</field>
        <field name="res_model">property.mandate</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_property_mandate_tree" />
        <field name="domain">[('operation_type','=','sale')]</field>
        <field name="context">{'group_by':'mandate_type'}</field>
    </record>


    <menuitem id="menu_rent_property_mandate" name="Mandats"
        parent="rental_management.menu_tenancy_details" action="action_property_mandate_rent"
        groups="rental_management.property_rental_manager,rental_management.property_rental_officer"
        sequence="0" />

    <menuitem id="menu_sale_property_mandate" name="Mandats"
        parent="rental_management.menu_property_vendor" action="action_property_mandate_sale"
        groups="rental_management.property_rental_manager,rental_management.property_rental_officer"
        sequence="0" />
</odoo>
