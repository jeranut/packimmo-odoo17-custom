<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_property_mandate_signed_upload_wizard_form" model="ir.ui.view">
        <field name="name">property.mandate.signed.upload.wizard.form</field>
        <field name="model">property.mandate.signed.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Téléverser mandat signé">
                <group>
                    <field name="mandate_id" readonly="1"/>
                    <field name="file" filename="filename" widget="binary"/>
                    <field name="filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_upload_signed_mandate" type="object" string="Valider" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
