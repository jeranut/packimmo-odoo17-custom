<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="property_details_form_view_inherit_brochure_video" model="ir.ui.view">
        <field name="name">property.details.form.brochure.video</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='brocher_access_token']" position="after">
                <field name="brochure_video_embed_code" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='property_brochure_url']/parent::div" position="after">
                <label for="brochure_video_url" string="Lien YouTube du bien"/>
                <div class="o_row o_property_youtube_block">
                    <field name="brochure_video_url"
                           widget="url"
                           placeholder="https://www.youtube.com/@packimmoimmobilier8119"/>
                </div>
            </xpath>

        </field>
    </record>
</odoo>