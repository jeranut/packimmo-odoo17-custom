<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_project_task_visit_wizard_form" model="ir.ui.view">
        <field name="name">project.task.visit.wizard.form</field>
        <field name="model">project.task.visit.wizard</field>
        <field name="arch" type="xml">
            <form string="Planifier une visite">
                <sheet>
                    <group>
                        <field name="task_id" readonly="1"/>
                        <field name="visit_client_id"
                               options="{'no_quick_create': True, 'no_create_edit': False}"/>
                        <field name="visit_observation"
                               placeholder="Observation pendant la visite..."/>
                    </group>
                </sheet>

                <footer>
                    <button name="action_confirm_visit"
                            type="object"
                            string="Confirmer la visite"
                            class="btn-primary"/>
                    <button string="Annuler"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>