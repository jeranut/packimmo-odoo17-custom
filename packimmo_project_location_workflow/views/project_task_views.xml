<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_task_search_packimmo_location" model="ir.ui.view">
        <field name="name">project.task.search.packimmo.location</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_search_form"/>
        <field name="arch" type="xml">

            <xpath expr="//search" position="inside">
                <filter string="Projet LOCATION"
                        name="filter_location_project"
                        domain="[('project_id.name', '=', 'LOCATION')]"/>

                <field name="property_id"/>
                <field name="property_type"/>
                <field name="property_subtype_id"/>
                <field name="property_subtype_name"/>
                <field name="property_mandate_type"/>
                <field name="property_mandate_end_date"/>
                <field name="property_landlord_id"/>
                <field name="property_address"/>

                <searchpanel>
                    <field name="property_type" string="Type de bien"/>
                    <field name="property_subtype_id" string="Sous-type du bien"/>
                    <field name="property_mandate_type" string="Type de mandat"/>
                    <field name="stage_id" string="Étape"/>
                    <field name="property_landlord_id" string="Propriétaire"/>
                </searchpanel>
            </xpath>

            <xpath expr="//group" position="inside">
                <filter string="Sous-type du bien"
                        name="group_by_property_subtype_name"
                        context="{'group_by': 'property_subtype_name'}"/>

                <filter string="Type de mandat"
                        name="group_by_property_mandate_type"
                        context="{'group_by': 'property_mandate_type'}"/>

                <filter string="Fin du mandat"
                        name="group_by_property_mandate_end_date"
                        context="{'group_by': 'property_mandate_end_date'}"/>
            </xpath>

        </field>
    </record>

    <record id="view_task_tree_packimmo_location" model="ir.ui.view">
        <field name="name">project.task.tree.packimmo.location</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="property_id" optional="show"/>
                <field name="property_type" optional="show"/>
                <field name="property_subtype_id" optional="show"/>
                <field name="property_subtype_name" optional="hide"/>
                <field name="property_mandate_type" optional="show"/>
                <field name="property_mandate_end_date" optional="show"/>
                <field name="date_deadline" optional="show"/>
                <field name="property_display_price" optional="show"/>
                <field name="property_display_currency_id" optional="hide"/>
                <field name="property_landlord_id" optional="show"/>
                <field name="property_address" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_task_kanban_packimmo_location" model="ir.ui.view">
        <field name="name">project.task.kanban.packimmo.location</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">

            <xpath expr="//kanban" position="inside">
                <field name="stage_id"/>
                <field name="property_id"/>
                <field name="property_image"/>
                <field name="property_type"/>
                <field name="property_subtype_id"/>
                <field name="property_subtype_name"/>
                <field name="property_mandate_type"/>
                <field name="property_mandate_end_date"/>
                <field name="date_deadline"/>
                <field name="property_display_price"/>
                <field name="property_display_currency_id"/>
                <field name="property_landlord_id"/>
                <field name="property_address"/>
                <field name="can_plan_visit"/>
            </xpath>

            <xpath expr="//div[hasclass('o_kanban_record_body')]/field[@name='tag_ids']" position="before">

                <div class="mb-2" t-if="record.property_id.raw_value">
                    <t t-if="record.property_image.raw_value">
                        <img alt="Image du bien"
                             t-att-src="kanban_image('project.task', 'property_image', record.id.raw_value)"
                             style="width:100%;height:12rem;object-fit:cover;border-radius:8px;"/>
                    </t>
                    <t t-else="">
                        <img alt="Image du bien"
                             src="/rental_management/static/src/img/property-placeholder.jpg"
                             style="width:100%;height:12rem;object-fit:cover;border-radius:8px;"/>
                    </t>
                </div>
            </xpath>

            <xpath expr="//strong[hasclass('o_kanban_record_title')]" position="replace">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <strong class="o_kanban_record_title flex-grow-1">
                        <s t-if="!record.active.raw_value">
                            <field name="name"/>
                        </s>
                        <t t-else="">
                            <field name="name"/>
                        </t>
                    </strong>
                    <span t-if="record.property_subtype_name.raw_value" class="badge rounded-pill text-bg-info">
                        <field name="property_subtype_name"/>
                    </span>
                </div>
            </xpath>

            <xpath expr="//div[@name='date_deadline']" position="replace"/>

            <xpath expr="//div[hasclass('o_kanban_record_body')]" position="inside">

                <div class="mt-2" t-if="record.can_plan_visit.raw_value">
                    <button name="action_open_visit_wizard"
                            type="object"
                            class="btn btn-sm btn-primary"
                            string="Planifier visite"/>
                </div>

                <div t-if="record.property_mandate_type.raw_value" class="text-muted">
                    <strong>Mandat :</strong>
                    <field name="property_mandate_type"/>
                </div>

                <div t-if="record.property_mandate_end_date.raw_value or (record.date_deadline.raw_value and !['1_done', '1_canceled'].includes(record.state.raw_value))"
                     class="text-muted d-flex flex-wrap align-items-center gap-1">
                    <strong>Fin mandat :</strong>
                    <span t-if="record.property_mandate_end_date.raw_value">
                        <field name="property_mandate_end_date"/>
                    </span>
                    <span t-if="record.date_deadline.raw_value and !['1_done', '1_canceled'].includes(record.state.raw_value)"
                          class="badge rounded-pill text-bg-light text-dark border">
                        <field name="date_deadline" widget="remaining_days"/>
                    </span>
                </div>

                <div t-if="record.property_display_price.raw_value" class="text-muted">
                    <strong>Loyer :</strong>
                    <field name="property_display_price"
                           widget="monetary"
                           options="{'currency_field': 'property_display_currency_id'}"/>
                    <span> / mois</span>
                </div>

                <div t-if="record.property_landlord_id.raw_value" class="text-muted">
                    <strong>Propriétaire :</strong>
                    <field name="property_landlord_id"/>
                </div>

                <div t-if="record.property_address.raw_value" class="text-muted">
                    <strong>Adresse :</strong>
                    <field name="property_address"/>
                </div>

            </xpath>

        </field>
    </record>

    <record id="view_task_form_packimmo_location" model="ir.ui.view">
        <field name="name">project.task.form.packimmo.location</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']/span[@id='end_button_box']" position="before">
                <button name="action_open_property"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-home"
                        invisible="not property_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Bien</span>
                    </div>
                </button>
                <field name="show_mandate_smart_button" invisible="1"/>
                <button name="action_open_property_mandates"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        invisible="not show_mandate_smart_button or mandate_count == 0">
                    <field name="mandate_count" widget="statinfo" string="Mandats"/>
                </button>
            </xpath>

            <xpath expr="//sheet" position="inside">
                <group string="Bien immobilier Packimmo">
                    <field name="property_id" readonly="1"/>
                    <field name="property_type" readonly="1"/>
                    <field name="property_subtype_id" readonly="1"/>
                    <field name="property_mandate_type" readonly="1"/>
                    <field name="property_mandate_end_date" readonly="1"/>
                    <field name="date_deadline" readonly="1"/>
                    <field name="property_display_price" readonly="1"/>
                    <field name="property_display_currency_id" readonly="1"/>
                    <field name="property_landlord_id" readonly="1"/>
                    <field name="property_address" readonly="1"/>
                </group>
            </xpath>

            <xpath expr="//field[@name='child_ids']/tree/field[@name='name']" position="after">
                <button name="action_validate_visit_and_regularize_mandate"
                        type="object"
                        string="Valider visite"
                        class="btn btn-sm btn-primary"
                        invisible="not show_visit_action_buttons or state == '1_canceled'"
                        confirm="Confirmez-vous la validation de la visite ? Le bien passera en REGULARISATION MANDAT et ne pourra plus revenir en VISITE ou BIENS DISPONIBLE."/>

                <button name="action_cancel_visit_and_return_kanban"
                        type="object"
                        string="Annuler visite"
                        class="btn btn-sm btn-secondary"
                        invisible="not show_visit_action_buttons or state == '1_canceled'"/>

                <button name="action_contract_location_visit"
                        type="object"
                        string="Contrater"
                        class="btn btn-sm btn-success"
                        invisible="not show_contract_action_button or state == '1_canceled'"/>

                <field name="show_visit_action_buttons" column_invisible="True"/>
                <field name="show_contract_action_button" column_invisible="True"/>
                <field name="visit_client_id" string="Client" optional="show"/>
                <field name="visit_observation" string="Observation" optional="show"/>
            </xpath>

        </field>
    </record>

</odoo>
