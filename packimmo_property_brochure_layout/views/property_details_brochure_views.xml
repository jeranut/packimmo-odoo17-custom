<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Nettoyage des anciennes vues/actions/menus séparés -->
    <delete id="menu_packimmo_property_brochure_settings" model="ir.ui.menu"/>
    <delete id="menu_packimmo_property_brochure_root" model="ir.ui.menu"/>
    <delete id="action_packimmo_property_brochure_settings" model="ir.actions.act_window"/>
    <delete id="packimmo_property_brochure_settings_tree" model="ir.ui.view"/>
    <delete id="packimmo_property_brochure_settings_form" model="ir.ui.view"/>

    <!-- Ajouter les paramètres brochure directement dans le formulaire original de chaque propriété/unité -->
    <record id="property_details_form_brochure_layout_inherit" model="ir.ui.view">
        <field name="name">property.details.form.brochure.layout.inherit</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view"/>
        <field name="arch" type="xml">

            <!-- Ajout de l'onglet Brochure juste après l'onglet Images -->
            <xpath expr="//page[.//field[@name='property_images_ids']]" position="after">

                <page string="Brochure">
                    <group>
                        <group string="Brochure publique">
                            <field name="brocher_access_token" readonly="1"/>

                            <field name="brochure_header_image"
                                   widget="image"
                                   filename="brochure_header_image_name"
                                   options="{'preview_image': 'brochure_header_image'}"/>

                            <field name="brochure_header_image_name" invisible="1"/>
                        </group>

                        <group string="Formulaire de contact">
                            <field name="brochure_contact_title"/>
                            <field name="brochure_contact_note"/>
                            <field name="brochure_video_url"
                                   placeholder="https://www.youtube.com/watch?v=..."/>
                        </group>
                    </group>

                    <group string="Lien public">
                        <div class="o_row">
                            <span>/property-brochure/</span>
                            <field name="brocher_access_token"
                                   nolabel="1"
                                   readonly="1"/>
                        </div>
                    </group>
                </page>

            </xpath>

        </field>
    </record>

</odoo>
