<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="packimmo_property_brochure_details" name="PACKIMMO Property Brochure Details">
        <t t-call="website.layout">
            <div class="pk-brochure-page">
                <section class="pk-hero">
                    <t t-if="property_id.brochure_header_image">
                        <img t-att-src="'/web/image/property.details/%s/brochure_header_image' % property_id.id"
                                            loading="eager"
                                            decoding="async" class="pk-hero-img" alt="Image d'entête"/>
                    </t>
                    <t t-elif="property_id.image">
                        <img t-att-src="'/web/image/property.details/%s/image' % property_id.id" loading="lazy" decoding="async" class="pk-hero-img" alt="Image du bien"/>
                    </t>
                    <t t-elif="property_id.is_images and property_id.property_images_ids">
                        <img t-att-src="'/web/image/property.images/%s/image' % property_id.property_images_ids[0].id"
                            loading="lazy"
                            decoding="async"
                            class="pk-hero-img"
                            alt="Image du bien"/>
                    </t>
                    <t t-else="">
                        <div class="pk-hero-placeholder">Property Image</div>
                    </t>

                    <div class="pk-hero-overlay"/>
                    <div class="pk-hero-content">
                        <div class="pk-status-row">
                            <span class="pk-badge" t-if="property_id.type">
                                <span t-field="property_id.type"/>
                            </span>
                            <span class="pk-badge pk-badge-sale" t-if="property_id.sale_lease">
                                <t t-if="property_id.sale_lease == 'for_sale'">À vendre</t>
                                <t t-elif="property_id.sale_lease == 'for_tenancy'">À louer</t>
                                <span t-else="" t-field="property_id.sale_lease"/>
                            </span>
                        </div>
                        <h1 t-field="property_id.name"/>
                        <div class="pk-unit-map-label" t-if="property_id.unit_map_label">
                            Lot: <span t-esc="property_id.unit_map_label"/>
                        </div>
                        <div class="pk-location" t-if="property_id.city_id or property_id.city or property_id.region_id">
                            <i class="fa fa-map-marker me-1"/>
                            <span t-if="property_id.city_id" t-field="property_id.city_id"/>
                            <span t-elif="property_id.city" t-field="property_id.city"/>
                            <span t-if="property_id.region_id">, <span t-field="property_id.region_id"/></span>
                        </div>
                       <div class="pk-hero-meta">

                        <span t-if="property_id.type != 'land' and property_id.unit_type">
                            <i class="fa fa-home"/>
                            <span t-field="property_id.unit_type"/>
                        </span>

                        <span t-if="property_id.usable_area">
                            <i class="fa fa-expand"/>
                            <span t-field="property_id.usable_area"/>
                            <span t-field="property_id.measure_unit"/>
                        </span>

                        <span t-if="property_id.type != 'land' and property_id.bed">

                            <t t-if="property_id.type == 'commercial'">
                                <i class="fa fa-th-large"/>
                                <span t-field="property_id.bed"/>
                                <t t-if="property_id.bed &gt; 1"> Espaces</t>
                                <t t-else=""> Espace</t>
                            </t>

                            <t t-else="">
                                <i class="fa fa-bed"/>
                                <span t-field="property_id.bed"/>
                                <t t-if="property_id.bed &gt; 1"> Chambres</t>
                                <t t-else=""> Chambre</t>
                            </t>

                        </span>

                    </div>
                    </div>
                </section>

                <main class="pk-content-wrap">
                    <div class="pk-main">
                        <section class="pk-card pk-gallery">
                            <t t-if="property_id.is_images and property_id.property_images_ids">
                                <div id="pkPropertyCarousel" class="carousel slide" data-bs-ride="false">
                                    <div class="carousel-inner">
                                        <t t-foreach="property_id.property_images_ids" t-as="img">
                                            <div t-att-class="'carousel-item active' if img_index == 0 else 'carousel-item'">

                                                <img t-att-src="'/web/image/property.images/%s/image' % img.id"
                                                    loading="lazy"
                                                    decoding="async"
                                                    class="pk-gallery-img"
                                                    alt="Property Image"/>

                                            </div>
                                        </t>
                                    </div>
                                    <button class="carousel-control-prev" type="button" data-bs-target="#pkPropertyCarousel" data-bs-slide="prev">
                                        <span class="carousel-control-prev-icon"/>
                                    </button>
                                    <button class="carousel-control-next" type="button" data-bs-target="#pkPropertyCarousel" data-bs-slide="next">
                                        <span class="carousel-control-next-icon"/>
                                    </button>
                                    <div class="pk-carousel-counter" aria-live="polite">
                                        <span class="pk-carousel-current">1</span>
                                        /
                                        <span t-esc="len(property_id.property_images_ids)"/>
                                    </div>
                                </div>
                            </t>
                            <t t-else="">
                                <img t-if="property_id.image" t-att-src="'/web/image/property.details/%s/image' % property_id.id"
                                    class="pk-gallery-img"
                                    loading="lazy"
                                    decoding="async"
                                    alt="Property Image"/>
                                <div t-else="" class="pk-gallery-placeholder">Property Image</div>
                            </t>
                        </section>

                       <section class="pk-section">
                            <h3>À propos de ce bien</h3>
                            <div t-if="property_id.detail_description"
                                t-field="property_id.detail_description"/>
                            <p t-else="">
                                Contactez-nous pour obtenir plus d'informations sur ce bien.
                            </p>
                        </section>

                        <section class="pk-section"
                                 t-if="property_id.unit_type or property_id.sale_lease or property_id.property_seq or property_id.total_area or property_id.usable_area or property_id.facing or (property_id.type != 'land' and property_id.floor_occupation) or (property_id.type == 'residential' and (property_id.parking or property_id.bed or property_id.bathroom))">
                            <h3>Caractéristiques du bien</h3>
                            <div class="pk-property-features-grid">
                                <div class="pk-info" t-if="property_id.type != 'land' and property_id.unit_type"><small>Type de bien</small><strong t-field="property_id.unit_type"/></div>
                                <div class="pk-info" t-if="property_id.sale_lease">
                                    <small>Type d'opération</small>
                                    <strong t-if="property_id.sale_lease == 'for_sale'">À vendre</strong>
                                    <strong t-elif="property_id.sale_lease == 'for_tenancy'">À louer</strong>
                                    <strong t-else="" t-field="property_id.sale_lease"/>
                                </div>
                                <div class="pk-info" t-if="property_id.property_seq"><small>Référence</small><strong t-field="property_id.property_seq"/></div>
                                <div class="pk-info" t-if="property_id.total_area"><small>Surface habitable</small><strong><span t-field="property_id.total_area"/> <span t-field="property_id.measure_unit"/></strong></div>
                                <div class="pk-info" t-if="property_id.usable_area"><small>Surface totale</small><strong><span t-field="property_id.usable_area"/> <span t-field="property_id.measure_unit"/></strong></div>
                                <div class="pk-info" t-if="property_id.type != 'land' and property_id.facing"><small>Orientation</small><strong t-field="property_id.facing"/></div>
                                <div class="pk-info" t-if="property_id.type != 'land' and property_id.floor_occupation">
                                    <small>Occupation des étages</small>
                                    <strong t-if="property_id.floor_occupation == 'whole_building'">Immeuble entier</strong>
                                    <strong t-elif="property_id.floor_occupation == 'plain_pied'">Bien de plain-pied</strong>
                                    <strong t-else="" t-field="property_id.floor_selection"/>
                                </div>
                                <div class="pk-info" t-if="property_id.type != 'land' and property_id.total_floor"><small>Nombre d'étages</small><strong t-field="property_id.total_floor"/></div>
                                <div class="pk-info" t-if="property_id.type == 'residential' and property_id.parking"><small>Parking</small><strong t-field="property_id.parking"/></div>
                                <div class="pk-info" t-if="property_id.type == 'residential' and property_id.bed"><small>Chambres</small><strong t-field="property_id.bed"/></div>
                                <div class="pk-info" t-if="property_id.type == 'residential' and property_id.bathroom"><small>Salles de bain</small><strong t-field="property_id.bathroom"/></div>
                            </div>
                        </section>
<!-- Terrain + Morcellement -->
                        <t t-set="is_land_morcellement"
                        t-value="property_id.type == 'land'
                                    and property_id.property_subtype_id
                                    and property_id.property_subtype_id.category == 'morcellement'"/>

                        <!-- Commodités :
                            1) amenities du bien si elles existent
                            2) sinon amenities du sous-projet si terrain morcellement
                        -->
                        <t t-set="brochure_amenities"
                        t-value="property_id.amenities_ids
                                    if property_id.amenities_ids
                                    else (
                                        property_id.subproject_id.subproject_amenity_ids
                                        if is_land_morcellement
                                        and property_id.subproject_id
                                        and property_id.subproject_id.avail_amenity
                                        and property_id.subproject_id.subproject_amenity_ids
                                        else False
                                    )"/>

                        <section class="pk-section" t-if="brochure_amenities">
                            <h3>Commodités</h3>

                            <div class="pk-amenities-grid">
                                <t t-foreach="brochure_amenities" t-as="amenity">
                                    <div class="pk-amenity-card" t-if="amenity.title">
                                        <div class="pk-amenity-logo">
                                            <img t-if="amenity.image"
                                                t-att-src="image_data_uri(amenity.image)"
                                                t-att-alt="amenity.title"/>
                                            <i t-else="" class="fa fa-check" aria-hidden="true"/>
                                        </div>

                                        <strong t-field="amenity.title"/>
                                    </div>
                                </t>
                            </div>
                        </section>

                       <t t-set="brochure_specifications"
   t-value="property_id.property_specification_ids
            if property_id.property_specification_ids
            else (
                property_id.subproject_id.subproject_specification_ids
                if is_land_morcellement
                and property_id.subproject_id
                and property_id.subproject_id.avail_specification
                and property_id.subproject_id.subproject_specification_ids
                else False
            )"/>

<section class="pk-section" t-if="brochure_specifications">
    <h3>Caractéristiques</h3>

    <div class="pk-specifications-grid">
        <t t-foreach="brochure_specifications" t-as="specification">
            <article class="pk-specification-card">
                <div class="pk-specification-logo">
                    <img t-if="specification.image"
                         t-att-src="image_data_uri(specification.image)"
                         t-att-alt="specification.title or 'Caractéristique'"/>
                    <i t-else="" class="fa fa-home" aria-hidden="true"/>
                </div>

                <div class="pk-specification-content">
                    <strong t-if="specification.title" t-field="specification.title"/>
                    <p t-if="specification.description" t-field="specification.description"/>
                    <small t-if="specification.description_line1" t-field="specification.description_line1"/>
                    <small t-if="specification.description_line2" t-field="specification.description_line2"/>
                    <small t-if="specification.description_line3" t-field="specification.description_line3"/>
                </div>
            </article>
        </t>
    </div>
</section>

                        <t t-set="brochure_connectivity"
   t-value="property_id.connectivity_ids
            if property_id.connectivity_ids
            else (
                property_id.subproject_id.subproject_connectivity_ids
                if is_land_morcellement
                and property_id.subproject_id
                and property_id.subproject_id.avail_nearby_connectivity
                and property_id.subproject_id.subproject_connectivity_ids
                else False
            )"/>

<section class="pk-section" t-if="brochure_connectivity">
    <h3>Connectivités à proximité</h3>

    <div class="pk-connectivity-grid">
        <t t-foreach="brochure_connectivity" t-as="connectivity">
            <article class="pk-connectivity-card">
                <div class="pk-connectivity-logo">
                    <img t-if="connectivity.image"
                         t-att-src="image_data_uri(connectivity.image)"
                         t-att-alt="connectivity.connectivity_id.name or 'Connectivité'"/>

                    <i t-else="" class="fa fa-map-marker" aria-hidden="true"/>
                </div>

                <strong t-if="connectivity.connectivity_id"
                        t-field="connectivity.connectivity_id"/>

                <span t-if="connectivity.name"
                      class="pk-connectivity-name"
                      t-field="connectivity.name"/>

                <span t-if="connectivity.distance"
                      class="pk-connectivity-distance"
                      t-field="connectivity.distance"/>
            </article>
        </t>
    </div>
</section>

                        <t t-set="floor_plans" t-value="property_id.floreplan_ids.filtered(lambda plan: plan.image)"/>
                        <section class="pk-section" t-if="property_id.is_floor_plan and floor_plans">
                            <h3>Plan de l'étage</h3>
                            <div id="pkFloorPlanCarousel" class="carousel slide pk-floor-plan-carousel" data-bs-ride="false">
                                <div class="carousel-inner">
                                    <t t-foreach="floor_plans" t-as="floor_plan">
                                        <div t-att-class="'carousel-item active' if floor_plan_index == 0 else 'carousel-item'">
                                            <div class="pk-floor-plan-title"
                                                 t-if="floor_plan.title"
                                                 style="position:absolute;top:16px;left:16px;z-index:5;display:inline-flex;align-items:center;gap:9px;max-width:calc(100% - 32px);padding:11px 17px;color:#fff;font-size:17px;font-weight:800;line-height:1.2;background:linear-gradient(135deg,#bf2925,#ee941f);border:2px solid rgba(255,255,255,.88);border-radius:10px;box-shadow:0 8px 20px rgba(148,31,28,.32);">
                                                <i class="fa fa-map-o" aria-hidden="true"/>
                                                <span t-field="floor_plan.title"/>
                                            </div>
                                            <img t-att-src="image_data_uri(floor_plan.image)"
                                                 t-att-alt="floor_plan.title or 'Plan de l’étage'"
                                                 class="pk-floor-plan-img"/>
                                        </div>
                                    </t>
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target="#pkFloorPlanCarousel" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon"/>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#pkFloorPlanCarousel" data-bs-slide="next">
                                    <span class="carousel-control-next-icon"/>
                                </button>
                                <div class="pk-carousel-counter" aria-live="polite">
                                    <span class="pk-carousel-current">1</span>
                                    /
                                    <span t-esc="len(floor_plans)"/>
                                </div>
                            </div>
                        </section>

                        <section class="pk-section" t-if="property_id.latitude and property_id.longitude">
                            <h3>Emplacement du bien</h3>
                            <div class="pk-map-box">
                                <iframe t-att-src="'https://maps.google.com/maps?q=%s,%s&amp;z=16&amp;output=embed' % (property_id.latitude, property_id.longitude)"
                                        width="100%"
                                        height="420"
                                        style="border:0;"
                                        loading="lazy"
                                        allowfullscreen="allowfullscreen">
                                </iframe>
                            </div>
                        </section>

                                                <!-- VIDEO -->
                        <!-- VIDEO -->
                    <section class="pk-section"
                            t-if="property_id.brochure_effective_video_embed_code">

                        <h3>Vidéo du bien</h3>

                        <div class="pk-video-box">
                            <t t-raw="property_id.brochure_effective_video_embed_code"/>
                        </div>

                    </section>
                    </div>

                    <aside class="pk-sidebar">
                        <div class="pk-side-card">
                            <div class="pk-side-title">
                                <t t-if="property_id.sale_lease == 'for_tenancy'">Loyer</t>
                                <t t-else="">Prix</t>
                            </div>
                            <div class="pk-price">
                                <span t-field="property_id.website_display_price"
                                      t-options="{'widget': 'monetary', 'display_currency': property_id.website_display_currency_id}"/>
                                <t t-if="property_id.sale_lease == 'for_tenancy'">
                                    / <span t-field="property_id.rent_unit"/>
                                </t>
                            </div>
                        </div>

                        <div class="pk-side-card">
                            <div class="pk-side-title">Partager ce bien</div>
                            <div class="pk-share">
                                <a t-att-href="'https://www.facebook.com/sharer/sharer.php?u=' + request.httprequest.url" target="_blank"><i class="fa fa-facebook"/></a>
                                <a t-att-href="'https://twitter.com/intent/tweet?url=' + request.httprequest.url" target="_blank"><i class="fa fa-twitter"/></a>
                                <a t-att-href="'https://www.linkedin.com/sharing/share-offsite/?url=' + request.httprequest.url" target="_blank"><i class="fa fa-linkedin"/></a>
                            </div>
                        </div>

                        <div class="pk-side-card">
                            <div class="pk-side-title">
                                <span t-esc="property_id.brochure_contact_title or 'Demande d’information'"/>
                            </div>
                            <div t-if="success" class="alert alert-success py-2">
                                Votre demande a été envoyée.
                            </div>
                            <p class="pk-contact-note" t-if="property_id.brochure_contact_note" t-field="property_id.brochure_contact_note"/>

                            <form action="/property-brochure/contact" method="post" class="pk-contact-form">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <input type="hidden" name="property_id" t-att-value="property_id.id"/>

                                <input type="text" name="name" required="required" placeholder="Votre nom *"/>
                                <input type="email" name="email" required="required" placeholder="Adresse email *"/>
                                <input type="tel" name="phone" placeholder="Téléphone"/>
                                <textarea name="message" rows="6" placeholder="Information complémentaire"/>
                                <button type="submit">Envoyer la demande</button>
                            </form>
                        </div>
                    </aside>
                </main>
            </div>
        </t>
    </template>
</odoo>
