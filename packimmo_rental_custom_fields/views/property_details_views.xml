<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="property_details_view_form_hide_available_button" model="ir.ui.view">
        <field name="name">property.details.view.form.hide.available.button</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_in_available']" position="attributes">
                <attribute name="invisible">stage != 'draft' or type != 'land'</attribute>
            </xpath>
        </field>
    </record>

    <record id="property_details_view_form_inherit_deadline" model="ir.ui.view">

        <field name="name">
            property.details.view.form.inherit.deadline
        </field>

        <field name="model">property.details</field>

        <field name="inherit_id" ref="rental_management.property_details_form_view" />

        <field name="arch" type="xml">

            <!-- Date limite d'aménagement -->
            <xpath expr="//field[@name='is_maintenance_service']" position="before">

                <field name="development_deadline_date" string="Date limite d'aménagement"
                    invisible="not is_maintenance_service and not is_extra_service" />

            </xpath>

            <!-- Notaire -->
            <xpath expr="(//field[@name='subproject_id'])[1]" position="after">
                <field name="notary_id"
                    string="Notaire"
                    placeholder="Choisir un notaire"
                    required="sale_lease == 'for_sale'"
                    invisible="sale_lease != 'for_sale'"
                    domain="[('is_company', '=', False)]"
                    options="{'no_quick_create': True}" />
            </xpath>
        </field>

    </record>
    <record id="property_details_view_form_inherit_pricing_type" model="ir.ui.view">
        <field name="name">property.details.view.form.inherit.pricing.type</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view" />
        <field name="arch" type="xml">

            <xpath expr="//field[@name='pricing_type']" position="attributes">
                <attribute name="readonly">type == 'land'</attribute>
            </xpath>

            <xpath expr="(//field[@name='price'])[2]" position="attributes">
                <attribute name="readonly">stage not in ['draft','available'] or pricing_type =='area_wise'</attribute>
            </xpath>

            <xpath expr="(//field[@name='total_maintenance'])[1]" position="attributes">
                <attribute name="readonly">maintenance_type == 'area_wise'</attribute>
            </xpath>

            <xpath expr="(//field[@name='total_area'])[1]" position="attributes">
                <attribute name="required">pricing_type == 'area_wise' or maintenance_type =='area_wise'</attribute>
            </xpath>

            <xpath expr="//field[@name='pricing_type']" position="after">
                <label for="foreign_price" string="Prix en devise" />
                <div>
                    <field name="foreign_price" class="oe_inline"
                        readonly="stage not in ['draft','available']" />
                    <field name="foreign_currency_id" class="oe_inline" nolabel="1"
                        readonly="stage not in ['draft','available']" />
                    <field name="exchange_rate_label" readonly="1" />
                </div>
                <field name="foreign_currency_code" invisible="1" />
                <field name="website_price_currency"
                    widget="radio"
                    options="{'horizontal': True}"
                    readonly="stage not in ['draft','available']"
                    invisible="not foreign_currency_code or foreign_currency_code == 'MGA'" />

            </xpath>
            <xpath expr="//field[@name='property_subtype_id']" position="after">
            <field name="property_category" />

            <field name="commercial_activity"
                placeholder="Ex : Restaurant, Boutique, Pharmacie..."
                invisible="type != 'commercial' or property_category != 'commercial'"
                required="type == 'commercial' and property_category == 'commercial'" />
</xpath>

        </field>
    </record>
    <record id="property_details_view_form_inherit_living_room" model="ir.ui.view">
        <field name="name">property.details.view.form.inherit.living.room</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view" />
        <field name="priority">99</field>
        <field name="arch" type="xml">

            <xpath expr="//group[.//field[@name='bed']]/field[@name='bed']" position="before">
                <field name="living_room_count"
                    string="Séjour"
                    invisible="type in ['land','industrial','commercial']" />
            </xpath>
            <xpath expr="//field[@name='living_room_count']" position="attributes">
                <attribute name="readonly">is_section_measurement</attribute>
            </xpath>

            <xpath expr="//field[@name='bed']" position="attributes">
                <attribute name="readonly">is_section_measurement</attribute>
            </xpath>

            <xpath expr="//field[@name='bathroom']" position="attributes">
                <attribute name="readonly">is_section_measurement</attribute>
            </xpath>
            <xpath expr="//field[@name='parking']" position="before">
                <field name="garage_count"
                    invisible="type in ['land','industrial','commercial']"
                    readonly="is_section_measurement" />
            </xpath>

            <xpath expr="//field[@name='parking']" position="attributes">
                <attribute name="readonly">is_section_measurement</attribute>
            </xpath>

        </field>
    </record>

    <record id="property_details_view_form_inherit_measure_per_floor" model="ir.ui.view">
        <field name="name">property.details.view.form.inherit.measure.per.floor</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='room_measurement_ids']/tree/field[@name='section_id']"
                position="after">
                <field name="property_total_floor" column_invisible="1" />
                <field name="property_floor_occupation" column_invisible="1" />
                <field name="property_floor_level_id" column_invisible="1" />
                <field name="measure_per_floor"
                    string="Étage"
                    domain="[('id', '=', property_floor_level_id)] if property_floor_occupation in ['plain_pied', 'multiple_floors'] else [('is_villa_basse', '=', False), ('number', '&gt;=', 0), ('number', '&lt;=', property_total_floor)]"
                    readonly="property_floor_occupation in ['plain_pied', 'multiple_floors']"
                    options="{'no_create': True, 'no_open': True}" />
            </xpath>
        </field>
    </record>

    <record id="property_details_view_form_inherit_floor_selection" model="ir.ui.view">
        <field name="name">property.details.view.form.inherit.floor.selection</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='floor']" position="replace">
                <field name="floor_occupation"
                    string="Occupation"
                    readonly="1"
                    invisible="type in ['land','industrial'] or total_floor != 0" />
                <field name="building_floor_occupation"
                    string="Occupation"
                    required="total_floor &gt; 0"
                    invisible="type in ['land','industrial'] or total_floor == 0" />
                <field name="floor_level_id"
                    string="Situé au"
                    domain="[('is_villa_basse', '=', False), ('number', '&gt;=', 0), ('number', '&lt;=', total_floor)]"
                    required="floor_occupation == 'multiple_floors'"
                    options="{'no_create': True, 'no_open': True}"
                    invisible="type in ['land','industrial'] or floor_occupation != 'multiple_floors'" />
            </xpath>
        </field>
    </record>

    <record id="property_details_view_form_inherit_address_placeholders" model="ir.ui.view">
        <field name="name">property.details.view.form.inherit.address.placeholders</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('o_address_format')]/field[@name='street']"
                position="attributes">
                <attribute name="placeholder">Adresse</attribute>
            </xpath>
            <xpath expr="//div[hasclass('o_address_format')]/field[@name='street2']"
                position="attributes">
                <attribute name="placeholder">Adresse 2</attribute>
            </xpath>
        </field>
    </record>

    <record id="property_details_view_form_inherit_detail_description" model="ir.ui.view">
    <field name="name">property.details.view.form.inherit.detail.description</field>
    <field name="model">property.details</field>
    <field name="inherit_id" ref="rental_management.property_details_form_view" />
    <field name="arch" type="xml">

        <xpath expr="//notebook" position="inside">
            <page name="detail_description" string="Description">
                <field name="detail_description"
                    nolabel="1"
                    widget="html"
                    placeholder="Description détaillée du bien..." />
            </page>
        </xpath>

    </field>
</record>
</odoo>
