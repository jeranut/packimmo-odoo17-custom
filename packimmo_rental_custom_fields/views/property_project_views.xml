<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="property_project_view_form_inherit_custom_fields" model="ir.ui.view">
        <field name="name">property.project.view.form.inherit.custom.fields</field>
        <field name="model">property.project</field>
        <field name="inherit_id" ref="rental_management.property_project_view_form" />
        <field name="arch" type="xml">

            <!-- Champs personnalisés -->
            <xpath expr="//field[@name='company_id']" position="after">

                <field name="property_land_name" placeholder="TANJONA II" invisible="property_type != 'land'" readonly="status == 'available'" />

                <field name="property_title_number" placeholder="6176-H" invisible="property_type != 'land'" readonly="status == 'available'" />

            </xpath>

            <!-- Cacher Country -->
            <xpath expr="//field[@name='country_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Cacher State -->
            <xpath expr="//field[@name='state_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Cacher Website -->
            <xpath expr="//field[@name='website']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Cacher Valuation Of -->
            <xpath expr="//field[@name='sale_lease']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='property_land_name']" position="attributes">
                <attribute name="required">property_type == 'land'</attribute>
            </xpath>

            <xpath expr="//field[@name='property_title_number']" position="attributes">
                <attribute name="required">property_type == 'land'</attribute>
            </xpath>

            <xpath expr="//field[@name='project_sequence']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="required">0</attribute>
            </xpath>

            <xpath expr="//field[@name='region_id']" position="attributes">
                <attribute name="options">{'no_create': False, 'no_quick_create': False,
                    'no_create_edit': False}</attribute>
            </xpath>

            <xpath expr="//field[@name='city_id']" position="attributes">
                <attribute name="options">{'no_create': False, 'no_quick_create': False,
                    'no_create_edit': False}</attribute>
            </xpath>


        </field>
    </record>

    <record id="property_project_view_tree_readonly_sequence" model="ir.ui.view">
        <field name="name">property.project.view.tree.readonly.sequence</field>
        <field name="model">property.project</field>
        <field name="inherit_id" ref="rental_management.property_project_view_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_sequence']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="property_project_view_form_allow_create_edit_landlord" model="ir.ui.view">
            <field name="name">property.project.view.form.allow.create.edit.landlord</field>
            <field name="model">property.project</field>
            <field name="inherit_id" ref="rental_management.property_project_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='landlord_id']" position="attributes">
                    <attribute name="options">{'no_quick_create': True, 'no_create_edit': False}</attribute>
                    <attribute name="context">{'default_user_type': 'landlord'}</attribute>
                </xpath>

            </field>
        </record>

    <record id="property_sub_project_view_form_inherit_hide_sale_lease" model="ir.ui.view">
        <field name="name">property.sub.project.view.form.inherit.hide.sale.lease</field>
        <field name="model">property.sub.project</field>
        <field name="inherit_id" ref="rental_management.property_sub_project_view_form" />
        <field name="arch" type="xml">

            <!-- Cacher Country -->
            <xpath expr="//field[@name='country_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Cacher State -->
            <xpath expr="//field[@name='state_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Cacher Website -->
            <xpath expr="//field[@name='website']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Cacher Valuation Of -->
            <xpath expr="//field[@name='sale_lease']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Readonly adresse -->
            <xpath expr="//field[@name='region_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='street']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='street2']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='city_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='zip']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            

        </field>
    </record>
    <record id="property_project_view_form_no_create_subtype" model="ir.ui.view">
    <field name="name">property.project.view.form.no.create.subtype</field>
    <field name="model">property.project</field>
    <field name="inherit_id" ref="rental_management.property_project_view_form" />
    <field name="arch" type="xml">
        <xpath expr="//field[@name='property_subtype_id']" position="attributes">
            <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
        </xpath>
    </field>
    </record>
    <record id="property_details_view_form_inherit_hide_address_fields" model="ir.ui.view">
        <field name="name">property.details.view.form.inherit.hide.address.fields</field>
        <field name="model">property.details</field>
        <field name="inherit_id" ref="rental_management.property_details_form_view" />
        <field name="arch" type="xml">

            <!-- Cacher Country -->
            <xpath expr="//field[@name='country_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Cacher State -->
            <xpath expr="//field[@name='state_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Cacher Website -->
            <xpath expr="//field[@name='website']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Readonly adresse -->
            <xpath expr="//field[@name='region_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='street']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='street2']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='city_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='zip']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

        </field>
    </record>

    <record id="rental_management.action_property_project" model="ir.actions.act_window">
        <field name="context">
            {
                'search_default_groupby_property_type': 1,
                'search_default_groupby_project_for': 2
            }
        </field>
    </record>

    <record id="property_project_view_form_inherit_address_placeholders" model="ir.ui.view">
        <field name="name">property.project.view.form.inherit.address.placeholders</field>
        <field name="model">property.project</field>
        <field name="inherit_id" ref="rental_management.property_project_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//group[@name='address_details']//field[@name='street']"
                position="attributes">
                <attribute name="placeholder">Adresse</attribute>
            </xpath>
            <xpath expr="//group[@name='address_details']//field[@name='street2']"
                position="attributes">
                <attribute name="placeholder">Adresse 2</attribute>
            </xpath>
        </field>
    </record>

    <record id="property_project_view_form_hide_coordinates" model="ir.ui.view">
        <field name="name">property.project.view.form.hide.coordinates</field>
        <field name="model">property.project</field>
        <field name="inherit_id" ref="rental_management.property_project_view_form" />
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('row')][.//field[@name='latitude'] and .//field[@name='longitude']]"
                position="replace">
                <field name="latitude" invisible="1" />
                <field name="longitude" invisible="1" />
            </xpath>
        </field>
    </record>

    <record id="property_sub_project_view_form_hide_coordinates" model="ir.ui.view">
        <field name="name">property.sub.project.view.form.hide.coordinates</field>
        <field name="model">property.sub.project</field>
        <field name="inherit_id" ref="rental_management.property_sub_project_view_form" />
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('row')][.//field[@name='latitude'] and .//field[@name='longitude']]"
                position="replace">
                <field name="latitude" invisible="1" />
                <field name="longitude" invisible="1" />
            </xpath>
        </field>
    </record>

</odoo>
