<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="properties_list_website_price_currency"
        inherit_id="property_list_dynamic_slider.properties_list_slider_template"
        name="Property List Website Price Currency">
        <xpath expr="//div[hasclass('pack-property-price')]" position="replace">
            <div t-if="not hide_price and property.website_display_price and property.website_display_price &gt; 0"
                class="pack-property-price">
                <span t-field="property.website_display_price"
                    t-options="{'widget': 'monetary', 'display_currency': property.website_display_currency_id}" />
                <t t-if="property.sale_lease == 'for_tenancy'">&#160;/Mois</t>
            </div>
        </xpath>
    </template>

    <template id="property_details_website_floor_selection"
        inherit_id="rental_management.rental_property_details"
        name="Property Details Website Floor Selection">
        <xpath expr="//div[hasclass('spec-box')][.//span[normalize-space()='Situé au']]"
            position="replace">
            <div class="spec-box" t-if="property_id.floor_occupation">
                <span class="text-muted text-uppercase prop-fs-10">
                    <t t-if="property_id.floor_occupation == 'multiple_floors'">Situé au</t>
                    <t t-else="">Occupation</t>
                </span>
                <div class="prop-details">
                    <t t-if="property_id.floor_occupation == 'whole_building'">Immeuble entier</t>
                    <span t-else="" t-field="property_id.floor_selection" />
                </div>
            </div>
        </xpath>
    </template>
</odoo>
