<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="create_sub_project_wizard_view_form_readonly_code" model="ir.ui.view">
        <field name="name">create.sub.project.wizard.view.form.readonly.code</field>
        <field name="model">subproject.creation</field>
        <field name="inherit_id" ref="rental_management.create_sub_project_wizard_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_sequence']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="required">0</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="property_sub_project_view_form_readonly_sequence" model="ir.ui.view">
        <field name="name">property.sub.project.view.form.readonly.sequence</field>
        <field name="model">property.sub.project</field>
        <field name="inherit_id" ref="rental_management.property_sub_project_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_sequence']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="required">0</attribute>
            </xpath>
        </field>
    </record>

    <record id="action_property_sub_project_morcellement" model="ir.actions.act_window">
        <field name="name">Morcellements</field>
        <field name="res_model">property.sub.project</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="rental_management.property_sub_project_view_tree" />
        <field name="domain">[('property_subtype_id.name', '=', 'Morcellement')]</field>
        <field name="context">
            {
                
            }
        </field>
    </record>

    <record id="property_sub_project_search_view_inherit_default_groups" model="ir.ui.view">
        <field name="name">property.sub.project.search.view.inherit.default.groups</field>
        <field name="model">property.sub.project</field>
        <field name="inherit_id" ref="rental_management.property_sub_project_search_view" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='groupby_project']" position="after">
                <filter string="Property Type" name="groupby_property_type" domain="[]"
                        context="{'group_by': 'property_type'}"/>
                <filter string="Project For" name="groupby_project_for" domain="[]"
                        context="{'group_by': 'project_for'}"/>
            </xpath>
        </field>
    </record>

    <record id="rental_management.action_property_sub_project" model="ir.actions.act_window">
        <field name="context">
            {
                
            }
        </field>
    </record>

    <record id="property_sub_project_view_form_no_create_subtype" model="ir.ui.view">
    <field name="name">property.sub.project.view.form.no.create.subtype</field>
    <field name="model">property.sub.project</field>
    <field name="inherit_id" ref="rental_management.property_sub_project_view_form" />
    <field name="arch" type="xml">
        <xpath expr="//field[@name='property_subtype_id']" position="attributes">
            <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
        </xpath>
    </field>
</record>

    <record id="property_sub_project_view_form_inherit_address_placeholders" model="ir.ui.view">
        <field name="name">property.sub.project.view.form.inherit.address.placeholders</field>
        <field name="model">property.sub.project</field>
        <field name="inherit_id" ref="rental_management.property_sub_project_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//group[@name='address_details']//field[@name='street']"
                position="attributes">
                <attribute name="placeholder">Adresse</attribute>
            </xpath>
            <xpath expr="//group[@name='address_details']//field[@name='street2']"
                position="attributes">
                <attribute name="placeholder">Adresse 2</attribute>
            </xpath>
        </field>
    </record>

    <menuitem id="menu_property_sub_project_morcellement" name="Morcellements" parent="rental_management.menu_property_vendor" action="action_property_sub_project_morcellement" sequence="20" />

</odoo>
