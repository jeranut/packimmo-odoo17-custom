<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Groupe : accès uniquement aux biens en location -->
    <record id="group_property_tenancy_only" model="res.groups">
        <field name="name">Property - Location uniquement</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <!-- Restriction Property Details pour cacher les biens de vente -->
    <record id="rule_property_details_tenancy_only" model="ir.rule">
        <field name="name">Property Details - Location uniquement</field>
        <field name="model_id" ref="rental_management.model_property_details"/>
        <field name="domain_force">
            [('sale_lease', '=', 'for_tenancy')]
        </field>
        <field name="groups"
               eval="[(4, ref('packimmo_rental_custom_fields.group_property_tenancy_only'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>
    <!-- Restriction Property Project : cacher les projets de vente -->
<record id="rule_property_project_no_sale" model="ir.rule">
    <field name="name">Property Project - Masquer les projets vente</field>
    <field name="model_id" ref="rental_management.model_property_project"/>
    <field name="domain_force">[('project_for', '!=', 'sale')]</field>
    <field name="groups" eval="[(4, ref('packimmo_rental_custom_fields.group_property_tenancy_only'))]"/>
    <field name="perm_read" eval="1"/>
    <field name="perm_write" eval="1"/>
    <field name="perm_create" eval="1"/>
    <field name="perm_unlink" eval="0"/>
</record>
<!-- Restriction Property Sub Project : cacher les sous-projets de vente -->
<record id="rule_property_sub_project_no_sale" model="ir.rule">
    <field name="name">Property Sub Project - Masquer les sous-projets vente</field>
    <field name="model_id" ref="rental_management.model_property_sub_project"/>
    <field name="domain_force">[('project_for', '!=', 'sale')]</field>
    <field name="groups" eval="[(4, ref('packimmo_rental_custom_fields.group_property_tenancy_only'))]"/>
    <field name="perm_read" eval="1"/>
    <field name="perm_write" eval="1"/>
    <field name="perm_create" eval="1"/>
    <field name="perm_unlink" eval="0"/>
</record>
<record id="rule_property_vendor_tenancy_only" model="ir.rule">
    <field name="name">Property Vendor - Hidden for Tenancy Users</field>
    <field name="model_id" ref="rental_management.model_property_vendor"/>
    <field name="domain_force">[('id', '=', 0)]</field>
    <field name="groups" eval="[(4, ref('packimmo_rental_custom_fields.group_property_tenancy_only'))]"/>
    <field name="perm_read" eval="1"/>
    <field name="perm_write" eval="0"/>
    <field name="perm_create" eval="0"/>
    <field name="perm_unlink" eval="0"/>
</record>

<!-- Multi-entreprise : compléments aux règles standard rental_management -->
<record id="rule_sale_invoice_company_only" model="ir.rule">
    <field name="name">Sale Invoice - Multi Company</field>
    <field name="model_id" ref="rental_management.model_sale_invoice"/>
    <field name="global" eval="True"/>
    <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
</record>

