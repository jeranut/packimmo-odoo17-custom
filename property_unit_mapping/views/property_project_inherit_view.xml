<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="property_project_view_form_inherit_unit_mapping" model="ir.ui.view">
        <field name="name">property.project.form.inherit.unit.mapping</field>
        <field name="model">property.project</field>
        <field name="inherit_id" ref="rental_management.property_project_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button string="Import Map Image"
                        name="action_open_import_unit_map_wizard"
                        type="object"
                        class="btn-secondary"
                        invisible="not has_multiple_units or property_type == 'land'"/>

                <button string="Préparer les lots cartographie"
                        name="action_prepare_unit_map_lines"
                        type="object"
                        class="btn-secondary"
                        invisible="not has_multiple_units and property_type != 'land'"/>

                <button string="Dessiner la cartographie"
                        name="action_open_unit_map_editor"
                        type="object"
                        class="btn-primary"
                        invisible="not has_multiple_units and property_type != 'land'"/>
                <button name="action_view_unit_map_website"
                        string="Voir côté site web"
                        type="object"
                        class="btn-primary"/>
            </xpath>

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Aperçu du plan" name="unit_map">
                    <field name="has_multiple_units" invisible="1"/>
                    <field name="property_type" invisible="1"/>
                    <field name="unit_map_image_name" invisible="1"/>

                    <group string="Configuration cartographie">
                        <group>
                            <field name="unit_count_for_map" string="Nombre d'unités" readonly="1"/>
                            <field name="unit_map_image"
                                   string="Image de fond"
                                   filename="unit_map_image_name"
                                   widget="image"
                                   class="oe_avatar"
                                   invisible="property_type == 'land'"/>
                        </group>
                    </group>

                    <separator string="Aperçu de la cartographie dessinée"/>
                    <div style="max-width:780px; border:1px solid #ddd; padding:8px; border-radius:8px; background:#fafafa;">
                        <field name="unit_map_preview_html"
                               readonly="1"
                               nolabel="1"
                               widget="html"/>
                    </div>

                    <separator string="liste des lots"/>
                    <field name="unit_map_line_ids"
                           nolabel="1"
                           readonly="1"
                           context="{'default_project_id': id}">

                        <tree create="0" edit="0" delete="0" open_form_view="0">
                            <field name="sequence" widget="handle"/>
                            <field name="unit_map_label" string="Référence Plan"/>
                            <field name="property_seq" readonly="1"/>
                            <field name="stage" readonly="1"/>
                        </tree>

                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
