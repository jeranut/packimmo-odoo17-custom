<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="property_unit_map_line_view_tree" model="ir.ui.view">
        <field name="name">property.unit.map.line.view.tree</field>
        <field name="model">property.unit.map.line</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="property_id"/>
                <field name="property_seq" readonly="1"/>
                <field name="stage" readonly="1"/>
                <field name="polygon_json"/>
            </tree>
        </field>
    </record>

    <record id="property_unit_map_line_view_form" model="ir.ui.view">
        <field name="name">property.unit.map.line.view.form</field>
        <field name="model">property.unit.map.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="project_id"/>
                        <field name="property_id" domain="[('property_project_id', '=', project_id)]"/>
                        <field name="stage" readonly="1"/>
                        <field name="polygon_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
