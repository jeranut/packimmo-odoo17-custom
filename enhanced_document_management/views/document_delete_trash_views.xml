<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="document_delete_trash_view_form" model="ir.ui.view">
        <field name="name">document.delete.trash.view.form</field>
        <field name="model">document.delete.trash</field>
        <field name="arch" type="xml">
            <form>
                <h2 class="move_trash_heading">Move to Trash/Delete Document Permanently</h2>
                <field name="document_file_id" readonly="1" invisible="1"/>
                <footer>
                    <button class="document_lock_wizard move_trash" type="object" name="document_move_trash">Move to
                        Trash
                    </button>
                    <button class="document_lock_wizard move_trash" type="object" name="document_permanent_delete">
                        Delete Permanently
                    </button>
                    <button class="document_cancel_wizard move_trash_wizard" special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
