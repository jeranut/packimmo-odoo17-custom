<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_invoice_form_view" model="ir.ui.view">
            <field name="name">sale.invoice.form.view</field>
            <field name="model">sale.invoice</field>
            <field name="arch" type="xml">
                <form create="false">
                    <field name="company_id" invisible="1" />
                    <field name="currency_id" invisible="1" />
                    <sheet>
                        <div class="oe_title">
                            <label for="property_sold_id" />
                            <h1>
                                <field name="property_sold_id" required="1" readonly="1" force_save="1"
                                    options="{'no_quick_create':True,'no_create_edit':True}" />
                            </h1>
                        </div>
                        <group>
                            <group>
                                <label for="invoice_id" class="mt-1" />
                                <div name="invoice_id">
                                    <field name="invoice_id" readonly="1" class="oe_inline"
                                        force_save="1"
                                        style="width:auto;" />
                                    <field name="payment_state" widget="badge"
                                        style="margin-left: 10px;width:auto;"
                                        decoration-success="payment_state=='paid'"
                                        decoration-danger="payment_state=='not_paid'"
                                        decoration-info="payment_state=='in_payment'"
                                        decoration-primary="payment_state=='partial'"
                                        decoration-warning="payment_state=='reversed'"
                                    />
                                </div>
                            </group>
                        </group>
                        <group string="Payment Information">
                            <group>
                                <field name="amount" widget="monetary" required="1" readonly="1"
                                    force_save="1" />
                            </group>
                            <group>
                                <field name="invoice_date" required="1" readonly="1" force_save="1" />
                                <field name="desc" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>